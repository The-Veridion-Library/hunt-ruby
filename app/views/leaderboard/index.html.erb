<div class="mb-6">
  <h1 class="page-title">🏆 Leaderboard</h1>
  <% if @current_rank %>
    <p class="page-subtitle">You're ranked <strong class="text-slate-700">#<%= @current_rank %></strong> with <strong class="text-slate-700"><%= current_user.points.to_i %> points</strong></p>
  <% else %>
    <p class="page-subtitle">Top hunters in the Veridion Book Hunt</p>
  <% end %>
</div>

<% if @users.any? %>
  <div class="card p-0 overflow-hidden">
    <table class="w-full text-sm">
      <thead class="bg-slate-50 border-b border-slate-100">
        <tr>
          <th class="text-left px-6 py-3 text-slate-500 font-medium w-16">Rank</th>
          <th class="text-left px-6 py-3 text-slate-500 font-medium">Hunter</th>
          <th class="text-left px-6 py-3 text-slate-500 font-medium">Points</th>
          <th class="text-left px-6 py-3 text-slate-500 font-medium">Badges</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-slate-100">
        <% @users.each_with_index do |user, index| %>
          <tr class="<%= user_signed_in? && user.id == current_user.id ? 'bg-amber-50' : 'hover:bg-slate-50' %> transition-colors">
            <td class="px-6 py-4 text-xl">
              <%= index == 0 ? '🥇' : index == 1 ? '🥈' : index == 2 ? '🥉' : "<span class='text-slate-500 text-sm font-medium'>##{index + 1}</span>".html_safe %>
            </td>
            <td class="px-6 py-4">
              <div class="flex items-center gap-3">
                <div class="w-8 h-8 rounded-full bg-indigo-100 text-indigo-700 flex items-center justify-center font-bold text-sm">
                  <%= user.username.first.upcase %>
                </div>
                <div>
                  <%= link_to user.username, profile_path(user.username), class: "font-medium text-slate-800 hover:text-indigo-600" %>
                  <% if user_signed_in? && user.id == current_user.id %>
                    <span class="text-xs text-amber-600 font-medium ml-1">← you</span>
                  <% end %>
                </div>
              </div>
            </td>
            <td class="px-6 py-4 font-semibold text-slate-700"><%= user.points.to_i %> pts</td>
            <td class="px-6 py-4 text-slate-600"><%= user.badges.count %> 🏅</td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% else %>
  <div class="card text-center py-12">
    <div class="text-5xl mb-3">🏆</div>
    <p class="text-slate-500">No hunters on the board yet — go find some books!</p>
    <%= link_to "View Map", map_path, class: "btn-primary inline-block mt-4" %>
  </div>
<% end %>
