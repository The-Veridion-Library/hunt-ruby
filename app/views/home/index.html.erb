<% if user_signed_in? %>
  <%# ── LOGGED-IN DASHBOARD ───────────────────────────────────────────────── %>

  <%# Pending / Rejected submission alerts %>
  <% if @my_pending.any? || @my_rejected.any? %>
    <div class="mb-6 space-y-3">
      <% @my_pending.each do |book| %>
        <div class="bg-amber-50 border border-amber-200 rounded-xl px-5 py-3 flex items-center justify-between gap-4">
          <div class="flex items-center gap-3">
            <span class="text-lg">⏳</span>
            <div>
              <p class="font-medium text-amber-800 text-sm"><%= book.title %> is under review</p>
              <p class="text-amber-600 text-xs">Submitted <%= time_ago_in_words(book.created_at) %> ago</p>
            </div>
          </div>
          <%= link_to "View", book_path(book), class: "text-amber-700 font-medium text-sm hover:underline flex-shrink-0" %>
        </div>
      <% end %>
      <% @my_rejected.each do |book| %>
        <% hours_left = [((book.updated_at + 48.hours - Time.current) / 1.hour).ceil, 0].max %>
        <div class="bg-red-50 border border-red-200 rounded-xl px-5 py-3 flex items-center justify-between gap-4">
          <div class="flex items-center gap-3">
            <span class="text-lg">❌</span>
            <div>
              <p class="font-medium text-red-800 text-sm"><%= book.title %> was not approved</p>
              <p class="text-red-600 text-xs">Deletes in <%= hours_left %> hour<%= 's' unless hours_left == 1 %> · <%= book.rejection_reason&.truncate(60) %></p>
            </div>
          </div>
          <%= link_to "Fix & Resubmit", new_book_path, class: "text-red-700 font-medium text-sm hover:underline flex-shrink-0" %>
        </div>
      <% end %>
    </div>
  <% end %>

  <%# Welcome + quick stats %>
  <div class="mb-8">
    <h1 class="text-2xl font-bold text-slate-900 mb-1">Welcome back, <%= current_user.username %>! 👋</h1>
    <p class="text-slate-500">Here's what's happening in the book hunt.</p>
  </div>

  <%# Stats row %>
  <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-8">
    <div class="card text-center">
      <p class="text-3xl font-bold text-indigo-600"><%= current_user.points.to_i %></p>
      <p class="text-slate-500 text-sm mt-1">Your Points</p>
    </div>
    <div class="card text-center">
      <p class="text-3xl font-bold text-amber-500"><%= current_user.books.approved.count %></p>
      <p class="text-slate-500 text-sm mt-1">Books Hidden</p>
    </div>
    <div class="card text-center">
      <p class="text-3xl font-bold text-emerald-500"><%= current_user.finds.count %></p>
      <p class="text-slate-500 text-sm mt-1">Books Found</p>
    </div>
    <div class="card text-center">
      <p class="text-3xl font-bold text-purple-500"><%= current_user.badges.count %></p>
      <p class="text-slate-500 text-sm mt-1">Badges Earned</p>
    </div>
  </div>

  <%# Quick actions %>
  <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-10">
    <%= link_to new_book_path, class: "card hover:shadow-md hover:-translate-y-0.5 transition-all group cursor-pointer text-center" do %>
      <div class="text-4xl mb-3">📬</div>
      <h3 class="font-semibold text-slate-800 group-hover:text-indigo-600 transition-colors">Submit a Book</h3>
      <p class="text-slate-500 text-sm mt-1">Share a book you'd like to hide in the community</p>
    <% end %>
    <%= link_to books_path, class: "card hover:shadow-md hover:-translate-y-0.5 transition-all group cursor-pointer text-center" do %>
      <div class="text-4xl mb-3">🔍</div>
      <h3 class="font-semibold text-slate-800 group-hover:text-indigo-600 transition-colors">Find Books</h3>
      <p class="text-slate-500 text-sm mt-1">Browse the catalog and go on a hunt</p>
    <% end %>
    <%= link_to leaderboard_path, class: "card hover:shadow-md hover:-translate-y-0.5 transition-all group cursor-pointer text-center" do %>
      <div class="text-4xl mb-3">🏆</div>
      <h3 class="font-semibold text-slate-800 group-hover:text-indigo-600 transition-colors">Leaderboard</h3>
      <p class="text-slate-500 text-sm mt-1">See how you rank against other hunters</p>
    <% end %>
  </div>

  <%# Two-column: activity feed + recent books %>
  <div class="grid grid-cols-1 lg:grid-cols-5 gap-6">

    <%# Friends activity feed %>
    <div class="lg:col-span-3">
      <h2 class="text-lg font-semibold text-slate-800 mb-4">📰 Friends Activity</h2>
      <% if @feed&.any? %>
        <div class="space-y-3">
          <% @feed.each do |find| %>
            <div class="card py-3 px-4 flex items-start gap-3">
              <div class="w-8 h-8 rounded-full bg-indigo-100 text-indigo-700 flex items-center justify-center font-bold text-sm flex-shrink-0">
                <%= find.user.username.first.upcase %>
              </div>
              <div class="flex-1 min-w-0">
                <p class="text-sm text-slate-700">
                  <%= link_to find.user.username, profile_path(find.user.username), class: "font-semibold hover:text-indigo-600" %>
                  found
                  <span class="font-medium text-slate-900"><%= find.book.title.truncate(40) %></span>
                </p>
                <p class="text-xs text-slate-400 mt-0.5"><%= find.found_at.strftime("%b %d at %I:%M %p") %> · +<%= find.points_awarded %> pts</p>
              </div>
            </div>
          <% end %>
        </div>
      <% else %>
        <div class="card text-center py-10">
          <p class="text-3xl mb-3">👥</p>
          <p class="text-slate-500 text-sm">No activity yet.</p>
          <p class="text-slate-400 text-xs mt-1">Add friends to see their finds here.</p>
          <%= link_to "Find Friends →", friendships_path, class: "text-indigo-600 text-sm font-medium hover:underline mt-3 inline-block" %>
        </div>
      <% end %>
    </div>

    <%# Recently hidden books %>
    <div class="lg:col-span-2">
      <h2 class="text-lg font-semibold text-slate-800 mb-4">📚 Recently Hidden</h2>
      <% if @featured_books.any? %>
        <div class="space-y-3">
          <% @featured_books.each do |book| %>
            <div class="card py-3 px-4 flex items-center gap-3">
              <% if book.front_cover.present? %>
                <img src="<%= book.front_cover %>" class="w-10 h-14 object-cover rounded flex-shrink-0">
              <% else %>
                <div class="w-10 h-14 bg-slate-100 rounded flex items-center justify-center text-xl flex-shrink-0">📖</div>
              <% end %>
              <div class="min-w-0">
                <p class="font-medium text-slate-800 text-sm truncate"><%= book.title %></p>
                <p class="text-slate-500 text-xs truncate">by <%= book.author %></p>
              </div>
              <%= link_to "View →", book_path(book), class: "ml-auto text-indigo-600 text-xs font-medium hover:underline flex-shrink-0" %>
            </div>
          <% end %>
          <div class="text-center pt-1">
            <%= link_to "Browse all books →", books_path, class: "text-indigo-600 text-sm font-medium hover:underline" %>
          </div>
        </div>
      <% else %>
        <div class="card text-center py-8">
          <p class="text-slate-400 text-sm">No books approved yet.</p>
        </div>
      <% end %>
    </div>
  </div>

<% else %>
  <%# ── LOGGED-OUT LANDING PAGE ───────────────────────────────────────────── %>

  <%# Hero %>
  <div class="text-center py-16 md:py-24 max-w-3xl mx-auto">
    <div class="text-6xl mb-6">📖</div>
    <h1 class="text-4xl md:text-5xl font-bold text-slate-900 leading-tight mb-5">
      Hide a Book.<br>
      <span class="text-indigo-600">Change Someone's Day.</span>
    </h1>
    <p class="text-lg text-slate-500 mb-8 max-w-xl mx-auto">
      The Veridion Book Hunt is a community book-sharing game. Hide books with QR codes at local spots, earn points when someone finds yours, and discover hidden treasures near you.
    </p>
    <div class="flex gap-3 justify-center flex-wrap">
      <%= link_to "Get Started Free", new_user_registration_path, class: "btn-primary btn-size-lg btn-plastic" %>
      <%= link_to "Browse the Catalog", books_path, class: "btn-outline btn-size-lg" %>
    </div>
  </div>

  <%# Live stats bar — Svelte powered %>
  <div id="svelte-stats"></div>

  <%# How it works %>
  <div class="py-16 border-t border-slate-100">
    <h2 class="text-2xl font-bold text-slate-900 text-center mb-10">How It Works</h2>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-4xl mx-auto">
      <div class="text-center">
        <div class="w-14 h-14 bg-indigo-100 rounded-2xl flex items-center justify-center text-2xl mx-auto mb-4">📬</div>
        <h3 class="font-semibold text-slate-800 mb-2 text-lg">1. Submit a Book</h3>
        <p class="text-slate-500 text-sm">Submit a book you own. Our team reviews it and approves books in good condition that comply with our content guidelines.</p>
      </div>
      <div class="text-center">
        <div class="w-14 h-14 bg-amber-100 rounded-2xl flex items-center justify-center text-2xl mx-auto mb-4">🏷</div>
        <h3 class="font-semibold text-slate-800 mb-2 text-lg">2. Print & Hide</h3>
        <p class="text-slate-500 text-sm">Once approved, print your unique QR label, stick it inside the book, and hide it at one of our partner locations — libraries, bookstores, cafes, and more.</p>
      </div>
      <div class="text-center">
        <div class="w-14 h-14 bg-emerald-100 rounded-2xl flex items-center justify-center text-2xl mx-auto mb-4">🎯</div>
        <h3 class="font-semibold text-slate-800 mb-2 text-lg">3. Earn Points</h3>
        <p class="text-slate-500 text-sm">When someone finds your book and scans the QR code, you both earn points. Climb the leaderboard, collect badges, and keep the hunt going.</p>
      </div>
    </div>
  </div>

  <%# Featured books section %>
  <% if @featured_books.any? %>
    <div class="py-12 border-t border-slate-100">
      <div class="flex items-center justify-between mb-6">
        <h2 class="text-2xl font-bold text-slate-900">Recently Hidden Books</h2>
        <%= link_to "View all →", books_path, class: "text-indigo-600 font-medium hover:underline" %>
      </div>
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-4">
        <% @featured_books.each do |book| %>
          <%= link_to book_path(book), class: "group" do %>
            <div class="card p-3 hover:shadow-md transition-all group-hover:-translate-y-0.5">
              <% if book.front_cover.present? %>
                <img src="<%= book.front_cover %>" class="w-full h-28 object-cover rounded-lg mb-2">
              <% else %>
                <div class="w-full h-28 bg-slate-100 rounded-lg mb-2 flex items-center justify-center text-3xl">📖</div>
              <% end %>
              <p class="text-xs font-medium text-slate-800 truncate"><%= book.title %></p>
              <p class="text-xs text-slate-400 truncate">by <%= book.author %></p>
            </div>
          <% end %>
        <% end %>
      </div>
    </div>
  <% end %>

  <%# CTA footer banner %>
  <div class="py-16 border-t border-slate-100">
    <div class="bg-indigo-600 rounded-3xl p-10 text-center text-white">
      <h2 class="text-3xl font-bold mb-3">Ready to join the hunt?</h2>
      <p class="text-indigo-200 mb-7 text-lg">It's free. It's fun. Your next favorite book might be around the corner.</p>
      <%= link_to "Create your account", new_user_registration_path, class: "btn-secondary btn-size-lg" %>
    </div>
  </div>

<% end %>
