<h1>Update Label #<%= @label.id %></h1>

<%= form_with model: @label do |f| %>
  <% if @label.errors.any? %>
    <div style="color:red">
      <% @label.errors.full_messages.each do |msg| %>
        <p><%= msg %></p>
      <% end %>
    </div>
  <% end %>

  <div>
    <%= f.label :book_id, "Book" %>
    <%= f.collection_select :book_id, @books, :id, :title, {}, { required: true } %>
  </div>

  <div>
    <%= f.label :location_id, "Location" %>
    <%= f.collection_select :location_id, @locations, :id, :name, {}, { required: true } %>
  </div>

  <div>
    <%= f.label :status, "Status" %>
    <%= f.select :status, Label::STATUSES.map { |s| [s.capitalize, s] }, {}, { required: true } %>
  </div>

  <%= f.submit "Update Label" %>
<% end %>

<%= link_to "Back to Label", label_path(@label) %>