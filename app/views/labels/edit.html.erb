<div class="max-w-xl">
  <h1 class="page-title">🏷 Create a Label</h1>
  <p class="page-subtitle">Generate a QR code for a hidden book.</p>

  <div class="card">
    <%= form_with model: @label do |f| %>
      <% if @label.errors.any? %>
        <div class="error-box">
          <% @label.errors.full_messages.each do |msg| %><p>• <%= msg %></p><% end %>
        </div>
      <% end %>

      <div class="form-group">
        <%= f.label :book_id, "Book", class: "form-label" %>
        <%= f.collection_select :book_id, @books, :id, :title, { prompt: "Select a book" }, { required: true, class: "form-input" } %>
      </div>

      <div class="form-group">
        <%= f.label :location_id, "Location", class: "form-label" %>
        <%= f.collection_select :location_id, @locations, :id, :name, { prompt: "Select a location" }, { required: true, class: "form-input" } %>
      </div>

      <div class="mt-6">
        <%= f.submit "Create Label", class: "btn-primary" %>
      </div>
    <% end %>
  </div>
</div>
