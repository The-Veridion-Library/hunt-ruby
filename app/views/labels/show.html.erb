<div class="max-w-xl">
  <div class="card mb-4">
    <div class="flex items-start justify-between mb-4">
      <div>
        <h1 class="text-xl font-bold text-slate-900">Label #<%= @label.id %></h1>
        <p class="text-slate-500 text-sm mt-0.5"><%= @label.book.title %></p>
      </div>
      <span class="badge-pill <%= @label.status == 'placed' ? 'bg-emerald-100 text-emerald-700' : 'bg-slate-100 text-slate-600' %>">
        <%= @label.status.capitalize %>
      </span>
    </div>
    <div class="grid grid-cols-2 gap-4 text-sm border-t border-slate-100 pt-4">
      <div>
        <span class="text-slate-500">Book</span>
        <p class="font-medium text-slate-800"><%= @label.book.title %></p>
      </div>
      <div>
        <span class="text-slate-500">Location</span>
        <p class="font-medium text-slate-800"><%= @label.location.name %></p>
      </div>
    </div>
  </div>

  <div class="card print:shadow-none">
    <h2 class="text-lg font-semibold text-slate-800 mb-1">QR Code</h2>
    <p class="text-slate-500 text-sm mb-4">Scan to find this book. Print and place inside the cover.</p>
    <div class="flex justify-center p-6 bg-white border border-slate-200 rounded-xl">
      <%= raw @qr_svg %>
    </div>
    <div class="mt-4 flex gap-3">
      <button onclick="window.print()" class="btn-secondary btn-size-sm">🖨 Print</button>
      <%= link_to "Edit Label", edit_label_path(@label), class: "btn-secondary text-sm" %>
    </div>
  </div>
</div>
