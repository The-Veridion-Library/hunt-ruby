<!DOCTYPE html>
<html>
  <head>
    <title>TVBH</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="csrf-param" content="<%= request_forgery_protection_token %>">
    <meta name="csrf-token" content="<%= form_authenticity_token %>">
    <%= vite_client_tag %>
    <%= vite_javascript_tag 'application', defer: true %>
  </head>
  <body>
    <nav style="background:#222; padding:10px; color:white; display:flex; gap:16px; align-items:center; flex-wrap:wrap;">
      <%= link_to "🏠 Home", root_path, style: "color:white;" %>
      <%= link_to "🗺 Map", map_path, style: "color:white;" %>
      <%= link_to "📚 Books", books_path, style: "color:white;" %>
      <%= link_to "🏷 Labels", labels_path, style: "color:white;" %>
      <%= link_to "📍 Locations", locations_path, style: "color:white;" %>
      <%= link_to "🎯 My Finds", finds_path, style: "color:white;" %>
      <%= link_to "🏆 Leaderboard", leaderboard_path, style: "color:white;" %>

      <% if user_signed_in? %>
        <% pending_count = Friendship.where(friend: current_user, status: 'pending').count %>
        <%= link_to "👥 Friends#{pending_count > 0 ? " (#{pending_count})" : ""}", friendships_path, style: "color:white;" %>
      <% end %>

      <span style="margin-left:auto;">
        <% if user_signed_in? %>
          <%= link_to "👤 #{current_user.username || current_user.email}", profile_path(current_user.username), style: "color:#aaa;" %>
          &nbsp;
          <%= button_to "Sign Out", destroy_user_session_path, method: :delete,
              style: "background:transparent; border:1px solid #aaa; color:white; cursor:pointer; padding:4px 10px;" %>
        <% else %>
          <%= link_to "Sign In", new_user_session_path, style: "color:white;" %>
          &nbsp;
          <%= link_to "Sign Up", new_user_registration_path, style: "color:white;" %>
        <% end %>
      </span>
    </nav>

    <div style="padding: 20px;">
      <% if notice.present? %>
        <p style="color:green;"><%= notice %></p>
      <% end %>
      <% if alert.present? %>
        <p style="color:red;"><%= alert %></p>
      <% end %>

      <%= yield %>
    </div>
  </body>
</html>