<!DOCTYPE html>
<html lang="en">
  <head>
    <title>Admin — TVBH</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="csrf-param" content="<%= request_forgery_protection_token %>">
    <meta name="csrf-token" content="<%= form_authenticity_token %>">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <%= vite_client_tag %>
    <%= vite_javascript_tag 'application', defer: true %>
    <%= vite_stylesheet_tag 'application', media: 'all' %>
    <style>body { font-family: 'Inter', sans-serif; }</style>
  </head>
  <body class="bg-slate-100 min-h-screen flex">

    <!-- Sidebar -->
    <aside class="w-56 bg-slate-900 min-h-screen flex flex-col fixed top-0 left-0 z-40">
      <div class="px-4 py-5 border-b border-slate-700">
        <%= link_to admin_root_path, class: "flex items-center gap-2 text-white font-bold" do %>
          <span class="text-xl">🛡️</span>
          <span>TVBH Admin</span>
        <% end %>
        <p class="text-slate-500 text-xs mt-1"><%= current_user.email %></p>
      </div>

      <nav class="flex-1 px-3 py-4 space-y-1 text-sm">
        <%= link_to "📊 Dashboard",  admin_root_path,           class: "admin-nav-link #{current_page?(admin_root_path) ? 'admin-nav-active' : ''}" %>
        <%= link_to "👥 Users",      admin_users_path,          class: "admin-nav-link #{controller_name == 'users' ? 'admin-nav-active' : ''}" %>
        <%= link_to "📚 Books",      admin_books_path,          class: "admin-nav-link #{controller_name == 'books' ? 'admin-nav-active' : ''}" %>
        <%= link_to "🏷 Labels",     admin_labels_path,         class: "admin-nav-link #{controller_name == 'labels' ? 'admin-nav-active' : ''}" %>
        <%= link_to "📍 Locations",  admin_locations_path,      class: "admin-nav-link #{controller_name == 'locations' ? 'admin-nav-active' : ''}" %>
        <%= link_to "🏅 Badges",     admin_badges_path,         class: "admin-nav-link #{controller_name == 'badges' ? 'admin-nav-active' : ''}" %>
      </nav>

      <div class="px-3 py-4 border-t border-slate-700 space-y-1 text-sm">
        <%= link_to "← Back to App", root_path, class: "admin-nav-link" %>
        <%= button_to "Sign Out", destroy_user_session_path, method: :delete,
            class: "w-full text-left admin-nav-link bg-transparent border-0 cursor-pointer" %>
      </div>
    </aside>

    <!-- Main content -->
    <div class="ml-56 flex-1 flex flex-col min-h-screen">
      <!-- Top bar -->
      <header class="bg-white border-b border-slate-200 px-6 py-3 flex items-center justify-between">
        <p class="text-slate-500 text-sm">Signed in as <span class="font-medium text-slate-700"><%= current_user.username %></span></p>
        <span class="badge-pill bg-red-100 text-red-700 text-xs">Admin</span>
      </header>

      <!-- Flash -->
      <% if notice.present? %>
        <div class="bg-emerald-50 border-b border-emerald-200 text-emerald-800 px-6 py-2 text-sm">✅ <%= notice %></div>
      <% end %>
      <% if alert.present? %>
        <div class="bg-red-50 border-b border-red-200 text-red-800 px-6 py-2 text-sm">⚠️ <%= alert %></div>
      <% end %>

      <main class="flex-1 p-6">
        <%= yield %>
      </main>
    </div>

  </body>
</html>
