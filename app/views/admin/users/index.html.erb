<div class="flex items-center justify-between mb-6">
  <div>
    <h1 class="page-title">👥 Users</h1>
    <p class="page-subtitle"><%= User.count %> total</p>
  </div>
  <%= form_with url: admin_users_path, method: :get, class: "flex gap-2" do |f| %>
    <%= f.text_field :q, value: params[:q], placeholder: "Search username or email...", class: "form-input w-64 text-sm py-1.5" %>
    <%= f.submit "Search", class: "btn-secondary text-sm py-1.5 px-3" %>
  <% end %>
</div>

<div class="card p-0 overflow-hidden">
  <table class="w-full text-sm">
    <thead class="bg-slate-50 border-b border-slate-100">
      <tr>
        <th class="text-left px-6 py-3 text-slate-500 font-medium">User</th>
        <th class="text-left px-6 py-3 text-slate-500 font-medium">Email</th>
        <th class="text-left px-6 py-3 text-slate-500 font-medium">Role</th>
        <th class="text-left px-6 py-3 text-slate-500 font-medium">Points</th>
        <th class="text-left px-6 py-3 text-slate-500 font-medium">Joined</th>
        <th class="px-6 py-3"></th>
      </tr>
    </thead>
    <tbody class="divide-y divide-slate-100">
      <% @users.each do |user| %>
        <tr class="hover:bg-slate-50">
          <td class="px-6 py-3 font-medium text-slate-800"><%= user.username %></td>
          <td class="px-6 py-3 text-slate-500"><%= user.email %></td>
          <td class="px-6 py-3">
            <span class="badge-pill <%= user.admin? ? 'bg-red-100 text-red-700' : 'bg-slate-100 text-slate-600' %>">
              <%= user.role %>
            </span>
          </td>
          <td class="px-6 py-3 text-slate-600"><%= user.points.to_i %></td>
          <td class="px-6 py-3 text-slate-400"><%= user.created_at.strftime("%b %d, %Y") %></td>
          <td class="px-6 py-3 text-right flex gap-2 justify-end">
            <%= link_to "View", admin_user_path(user), class: "text-indigo-600 hover:underline" %>
            <%= link_to "Edit", edit_admin_user_path(user), class: "text-slate-500 hover:underline" %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
