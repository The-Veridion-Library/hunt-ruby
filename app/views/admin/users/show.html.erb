<div class="flex items-center gap-3 mb-6">
  <%= link_to "← Users", admin_users_path, class: "text-slate-400 hover:text-slate-600 text-sm" %>
</div>

<div class="grid grid-cols-3 gap-6">
  <div class="col-span-1 space-y-4">
    <div class="card">
      <div class="w-14 h-14 rounded-full bg-indigo-100 text-indigo-700 flex items-center justify-center font-bold text-2xl mb-3">
        <%= @user.username.first.upcase %>
      </div>
      <h1 class="text-xl font-bold text-slate-900"><%= @user.username %></h1>
      <p class="text-slate-500 text-sm"><%= @user.email %></p>
      <div class="mt-3 space-y-2 text-sm">
        <div class="flex justify-between"><span class="text-slate-500">Role</span> <span class="badge-pill <%= @user.admin? ? 'bg-red-100 text-red-700' : 'bg-slate-100 text-slate-600' %>"><%= @user.role %></span></div>
        <div class="flex justify-between"><span class="text-slate-500">Points</span> <span class="font-medium"><%= @user.points.to_i %></span></div>
        <div class="flex justify-between"><span class="text-slate-500">Books</span> <span class="font-medium"><%= @books.count %></span></div>
        <div class="flex justify-between"><span class="text-slate-500">Finds</span> <span class="font-medium"><%= @finds.count %></span></div>
        <div class="flex justify-between"><span class="text-slate-500">Badges</span> <span class="font-medium"><%= @badges.count %></span></div>
        <div class="flex justify-between"><span class="text-slate-500">Joined</span> <span class="font-medium"><%= @user.created_at.strftime("%b %d, %Y") %></span></div>
      </div>
      <div class="mt-4 flex gap-2">
        <%= link_to "Edit", edit_admin_user_path(@user), class: "btn-secondary text-sm py-1.5 px-3" %>
        <%= button_to "Delete", admin_user_path(@user), method: :delete,
            class: "btn-danger text-sm py-1.5 px-3",
            data: { confirm: "Delete #{@user.username}? This cannot be undone." } %>
      </div>
    </div>
  </div>

  <div class="col-span-2 space-y-4">
    <div class="card p-0 overflow-hidden">
      <div class="px-6 py-3 border-b border-slate-100 font-semibold text-slate-800">Books Hidden</div>
      <% if @books.any? %>
        <div class="divide-y divide-slate-100">
          <% @books.each do |book| %>
            <div class="px-6 py-3 flex justify-between items-center text-sm">
              <%= link_to book.title, admin_book_path(book), class: "font-medium text-slate-800 hover:text-indigo-600" %>
              <span class="badge-pill <%= book.status == 'hidden' ? 'bg-amber-100 text-amber-700' : 'bg-emerald-100 text-emerald-700' %>"><%= book.status %></span>
            </div>
          <% end %>
        </div>
      <% else %>
        <p class="px-6 py-4 text-slate-400 text-sm">No books.</p>
      <% end %>
    </div>

    <div class="card p-0 overflow-hidden">
      <div class="px-6 py-3 border-b border-slate-100 font-semibold text-slate-800">Recent Finds</div>
      <% if @finds.any? %>
        <div class="divide-y divide-slate-100">
          <% @finds.first(10).each do |find| %>
            <div class="px-6 py-3 flex justify-between text-sm">
              <span class="text-slate-700"><%= find.book.title %></span>
              <span class="text-slate-400"><%= find.found_at.strftime("%b %d, %Y") %> · +<%= find.points_awarded %> pts</span>
            </div>
          <% end %>
        </div>
      <% else %>
        <p class="px-6 py-4 text-slate-400 text-sm">No finds.</p>
      <% end %>
    </div>
  </div>
</div>
