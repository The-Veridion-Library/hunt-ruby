<div class="flex items-center gap-3 mb-6">
  <%= link_to "← #{@user.username}", admin_user_path(@user), class: "text-slate-400 hover:text-slate-600 text-sm" %>
</div>

<div class="max-w-lg">
  <h1 class="page-title">Edit User</h1>
  <div class="card mt-4">
    <%= form_with model: [:admin, @user] do |f| %>
      <% if @user.errors.any? %>
        <div class="error-box"><% @user.errors.full_messages.each do |m| %><p>• <%= m %></p><% end %></div>
      <% end %>

      <div class="form-group">
        <%= f.label :username, class: "form-label" %>
        <%= f.text_field :username, class: "form-input" %>
      </div>
      <div class="form-group">
        <%= f.label :email, class: "form-label" %>
        <%= f.email_field :email, class: "form-input" %>
      </div>
      <div class="form-group">
        <%= f.label :role, class: "form-label" %>
        <%= f.select :role, User::ROLES.map { |r| [r.capitalize, r] }, {}, { class: "form-input" } %>
      </div>
      <div class="form-group">
        <%= f.label :points, class: "form-label" %>
        <%= f.number_field :points, class: "form-input" %>
      </div>
      <div class="form-group">
        <%= f.label :bio, class: "form-label" %>
        <%= f.text_area :bio, rows: 3, class: "form-input" %>
      </div>
      <div class="flex gap-3 mt-6">
        <%= f.submit "Save Changes", class: "btn-primary" %>
        <%= link_to "Cancel", admin_user_path(@user), class: "btn-secondary" %>
      </div>
    <% end %>
  </div>
</div>
