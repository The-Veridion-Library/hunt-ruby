<div class="flex items-center justify-between mb-6">
  <div>
    <h1 class="page-title">🧭 Hunts</h1>
    <div class="flex gap-3 mt-1 text-sm">
      <% if @active_count > 0 %>
        <span class="text-emerald-600 font-medium">🟢 <%= @active_count %> active</span>
      <% end %>
      <% if @upcoming_count > 0 %>
        <span class="text-blue-600 font-medium">⏳ <%= @upcoming_count %> upcoming</span>
      <% end %>
      <% if @ended_count > 0 %>
        <span class="text-slate-600 font-medium">⚑ <%= @ended_count %> ended</span>
      <% end %>
    </div>
  </div>
  <div class="flex gap-2 flex-wrap">
    <%= link_to "All", admin_hunts_path, class: "btn-secondary text-sm py-1.5 #{params[:status].blank? ? 'bg-slate-200' : ''}" %>
    <%= link_to "🟢 Active", admin_hunts_path(status: 'active'), class: "btn-secondary text-sm py-1.5 #{params[:status] == 'active' ? 'bg-emerald-100 border-emerald-300 text-emerald-700' : ''}" %>
    <%= link_to "⏳ Upcoming", admin_hunts_path(status: 'upcoming'), class: "btn-secondary text-sm py-1.5 #{params[:status] == 'upcoming' ? 'bg-blue-100 border-blue-300 text-blue-700' : ''}" %>
    <%= link_to "⚑ Ended", admin_hunts_path(status: 'ended'), class: "btn-secondary text-sm py-1.5 #{params[:status] == 'ended' ? 'bg-slate-200' : ''}" %>
  </div>
</div>

<div class="card p-0 overflow-hidden">
  <table class="w-full text-sm">
    <thead class="bg-slate-50 border-b border-slate-100">
      <tr>
        <th class="text-left px-5 py-3 text-slate-500 font-medium">Hunt</th>
        <th class="text-left px-5 py-3 text-slate-500 font-medium">Created by</th>
        <th class="text-left px-5 py-3 text-slate-500 font-medium">Window</th>
        <th class="text-left px-5 py-3 text-slate-500 font-medium">Books</th>
        <th class="text-left px-5 py-3 text-slate-500 font-medium">Participants</th>
        <th class="text-left px-5 py-3 text-slate-500 font-medium">Status</th>
        <th class="px-5 py-3"></th>
      </tr>
    </thead>
    <tbody class="divide-y divide-slate-100">
      <% @hunts.each do |hunt| %>
        <tr class="hover:bg-slate-50 <%= 'bg-emerald-50' if hunt.active? %> <%= 'bg-blue-50' if hunt.upcoming? %>">
          <td class="px-5 py-3">
            <p class="font-medium text-slate-800"><%= hunt.title %></p>
            <p class="text-slate-400 text-xs max-w-[260px] truncate"><%= hunt.description.to_s.presence || '—' %></p>
          </td>
          <td class="px-5 py-3 text-slate-600"><%= hunt.user.username %></td>
          <td class="px-5 py-3 text-slate-500 text-xs">
            <div><%= hunt.start_date.strftime('%b %d, %Y %I:%M %p') %></div>
            <div>→ <%= hunt.end_date.strftime('%b %d, %Y %I:%M %p') %></div>
          </td>
          <td class="px-5 py-3 text-slate-600"><%= hunt.books.count %></td>
          <td class="px-5 py-3 text-slate-600"><%= hunt.hunt_participants.count %></td>
          <td class="px-5 py-3">
            <span class="badge-pill <%= case hunt.status
              when 'active' then 'bg-emerald-100 text-emerald-700'
              when 'upcoming' then 'bg-blue-100 text-blue-700'
              else 'bg-slate-100 text-slate-600'
              end %>">
              <%= hunt.status.humanize %>
            </span>
          </td>
          <td class="px-5 py-3 text-right">
            <%= link_to "Review →", admin_hunt_path(hunt), class: "text-indigo-600 hover:underline font-medium" %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
