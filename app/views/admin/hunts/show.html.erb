<div class="flex items-center gap-3 mb-6">
  <%= link_to "← Hunts", admin_hunts_path, class: "text-slate-400 hover:text-slate-600 text-sm" %>
</div>

<div class="grid grid-cols-3 gap-6">
  <div class="col-span-1 space-y-4">
    <div class="card">
      <h1 class="text-lg font-bold text-slate-900"><%= @hunt.title %></h1>
      <p class="text-slate-500 text-sm mt-1"><%= @hunt.description.to_s.presence || 'No description.' %></p>

      <div class="space-y-2 text-sm border-t border-slate-100 pt-3 mt-3">
        <div class="flex justify-between"><span class="text-slate-500">Creator</span> <span class="font-medium"><%= @hunt.user.username %></span></div>
        <div class="flex justify-between"><span class="text-slate-500">Status</span>
          <span class="badge-pill <%= case @hunt.status
            when 'active' then 'bg-emerald-100 text-emerald-700'
            when 'upcoming' then 'bg-blue-100 text-blue-700'
            else 'bg-slate-100 text-slate-600'
            end %>"><%= @hunt.status.humanize %></span>
        </div>
        <div><span class="text-slate-500">Start</span><p class="font-medium text-xs mt-0.5"><%= @hunt.start_date.strftime('%b %d, %Y %I:%M %p') %></p></div>
        <div><span class="text-slate-500">End</span><p class="font-medium text-xs mt-0.5"><%= @hunt.end_date.strftime('%b %d, %Y %I:%M %p') %></p></div>
        <div class="flex justify-between"><span class="text-slate-500">Books</span><span class="font-medium"><%= @hunt_books.count %></span></div>
        <div class="flex justify-between"><span class="text-slate-500">Participants</span><span class="font-medium"><%= @hunt.hunt_participants.count %></span></div>
      </div>

      <div class="mt-4 pt-4 border-t border-slate-100 flex flex-wrap gap-2">
        <% (Hunt::STATUSES - [@hunt.status]).each do |status| %>
          <%= button_to "Set #{status.humanize}", set_status_admin_hunt_path(@hunt), method: :patch,
              params: { status: status }, class: "btn-secondary text-xs py-1.5 px-2.5" %>
        <% end %>
        <%= button_to "↻ Recalculate Scores", recalculate_scores_admin_hunt_path(@hunt), method: :post,
            class: "btn-secondary text-xs py-1.5 px-2.5" %>
        <%= button_to "🏆 Award Winner Badge", award_winner_badge_admin_hunt_path(@hunt), method: :post,
            class: "btn-success text-xs py-1.5 px-2.5" %>
        <%= button_to "🗑 Delete Hunt", admin_hunt_path(@hunt), method: :delete,
            class: "btn-danger text-xs py-1.5 px-2.5", data: { confirm: 'Delete this hunt?' } %>
      </div>
    </div>
  </div>

  <div class="col-span-2 space-y-4">
    <div class="card p-0 overflow-hidden">
      <div class="px-5 py-3 border-b border-slate-100 font-semibold text-slate-800">Leaderboard (<%= @leaderboard.count %>)</div>
      <% if @leaderboard.any? %>
        <table class="w-full text-sm">
          <thead class="bg-slate-50 border-b border-slate-100">
            <tr>
              <th class="text-left px-5 py-2 text-slate-500 font-medium">Rank</th>
              <th class="text-left px-5 py-2 text-slate-500 font-medium">User</th>
              <th class="text-left px-5 py-2 text-slate-500 font-medium">Score</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-100">
            <% @leaderboard.each_with_index do |entry, index| %>
              <tr>
                <td class="px-5 py-2 text-slate-700 font-medium">#<%= index + 1 %></td>
                <td class="px-5 py-2">
                  <%= link_to entry.user.username, admin_user_path(entry.user), class: "text-slate-800 hover:text-indigo-600 font-medium" %>
                </td>
                <td class="px-5 py-2 text-slate-700"><%= entry.score %> pts</td>
              </tr>
            <% end %>
          </tbody>
        </table>
      <% else %>
        <p class="px-5 py-4 text-slate-400 text-sm">No participants yet.</p>
      <% end %>
    </div>

    <div class="card p-0 overflow-hidden">
      <div class="px-5 py-3 border-b border-slate-100 font-semibold text-slate-800">Books in Hunt (<%= @hunt_books.count %>)</div>
      <% if @hunt_books.any? %>
        <div class="divide-y divide-slate-100">
          <% @hunt_books.each do |book| %>
            <div class="px-5 py-3 flex justify-between items-center text-sm">
              <%= link_to book.title, admin_book_path(book), class: "font-medium text-slate-800 hover:text-indigo-600" %>
              <span class="text-slate-400"><%= book.author %></span>
            </div>
          <% end %>
        </div>
      <% else %>
        <p class="px-5 py-4 text-slate-400 text-sm">No books in this hunt.</p>
      <% end %>
    </div>
  </div>
</div>
