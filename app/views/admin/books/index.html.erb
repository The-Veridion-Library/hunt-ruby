<div class="flex items-center justify-between mb-6">
  <h1 class="page-title">📚 Books</h1>
  <div class="flex gap-2">
    <%= link_to "All", admin_books_path, class: "btn-secondary text-sm py-1.5 #{params[:status].blank? ? 'bg-slate-200' : ''}" %>
    <%= link_to "Hidden", admin_books_path(status: 'hidden'), class: "btn-secondary text-sm py-1.5 #{params[:status] == 'hidden' ? 'bg-slate-200' : ''}" %>
    <%= link_to "Found", admin_books_path(status: 'found'), class: "btn-secondary text-sm py-1.5 #{params[:status] == 'found' ? 'bg-slate-200' : ''}" %>
  </div>
</div>

<div class="card p-0 overflow-hidden">
  <table class="w-full text-sm">
    <thead class="bg-slate-50 border-b border-slate-100">
      <tr>
        <th class="text-left px-6 py-3 text-slate-500 font-medium">Title</th>
        <th class="text-left px-6 py-3 text-slate-500 font-medium">Author</th>
        <th class="text-left px-6 py-3 text-slate-500 font-medium">Hidden by</th>
        <th class="text-left px-6 py-3 text-slate-500 font-medium">Status</th>
        <th class="text-left px-6 py-3 text-slate-500 font-medium">Added</th>
        <th class="px-6 py-3"></th>
      </tr>
    </thead>
    <tbody class="divide-y divide-slate-100">
      <% @books.each do |book| %>
        <tr class="hover:bg-slate-50">
          <td class="px-6 py-3 font-medium text-slate-800 max-w-[180px] truncate"><%= book.title %></td>
          <td class="px-6 py-3 text-slate-600"><%= book.author %></td>
          <td class="px-6 py-3 text-slate-500"><%= link_to book.user.username, admin_user_path(book.user), class: "hover:text-indigo-600" %></td>
          <td class="px-6 py-3"><span class="badge-pill <%= book.status == 'hidden' ? 'bg-amber-100 text-amber-700' : 'bg-emerald-100 text-emerald-700' %>"><%= book.status %></span></td>
          <td class="px-6 py-3 text-slate-400"><%= book.created_at.strftime("%b %d, %Y") %></td>
          <td class="px-6 py-3 text-right flex gap-2 justify-end">
            <%= link_to "View", admin_book_path(book), class: "text-indigo-600 hover:underline" %>
            <%= button_to "Delete", admin_book_path(book), method: :delete, class: "text-red-500 hover:underline bg-transparent border-0 cursor-pointer p-0 text-sm", data: { confirm: "Delete this book?" } %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
