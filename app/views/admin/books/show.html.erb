<div class="flex items-center gap-3 mb-6">
  <%= link_to "← Books", admin_books_path, class: "text-slate-400 hover:text-slate-600 text-sm" %>
</div>

<%# ── Modals ─────────────────────────────────────────────────────────────────── %>
<%= render "shared/modal",
      id: "modal-approve",
      title: "Approve this book?",
      body: "A label will be created at the preferred location (#{@book.preferred_location&.name || 'none set'}). The submitter will be able to print their QR label.",
      confirm_label: "✅ Approve",
      confirm_class: "btn-success",
      form_action: approve_admin_book_path(@book),
      form_method: :patch %>

<%= render "shared/modal",
      id: "modal-reject",
      title: "Reject this submission",
      confirm_label: "❌ Reject",
      confirm_class: "btn-danger",
      form_action: reject_admin_book_path(@book),
      form_method: :patch,
      textarea_name: :rejection_reason,
      textarea_label: "Reason for rejection",
      textarea_required: true,
      textarea_placeholder: "e.g. Book condition does not meet our guidelines." %>

<%= render "shared/modal",
      id: "modal-delete",
      title: "Delete this book?",
      body: "This will permanently remove the book, all its labels, and all finds. This cannot be undone.",
      confirm_label: "Delete",
      confirm_class: "btn-danger",
      form_action: admin_book_path(@book),
      form_method: :delete %>

<%= render "shared/modal",
      id: "modal-flag",
      title: "Flag this book?",
      body: "Flagging marks the book for further human review.",
      confirm_label: "🚩 Flag",
      confirm_class: "btn-secondary",
      form_action: flag_admin_book_path(@book),
      form_method: :patch %>

<div class="grid grid-cols-3 gap-6">

  <%# ── Left: Submission Details ──────────────────────────────────────────── %>
  <div class="col-span-1 space-y-4">

    <% if @book.front_cover.present? || @book.back_cover.present? %>
      <div class="card p-3">
        <p class="text-xs text-slate-500 font-medium uppercase tracking-wide mb-2">Cover Photos</p>
        <div class="flex gap-2">
          <% if @book.front_cover.present? %>
            <div class="flex-1">
              <p class="text-xs text-slate-400 mb-1">Front</p>
              <img src="<%= @book.front_cover %>" class="w-full h-32 object-cover rounded-lg">
            </div>
          <% end %>
          <% if @book.back_cover.present? %>
            <div class="flex-1">
              <p class="text-xs text-slate-400 mb-1">Back</p>
              <img src="<%= @book.back_cover %>" class="w-full h-32 object-cover rounded-lg">
            </div>
          <% end %>
        </div>
      </div>
    <% else %>
      <div class="card text-center text-slate-400 text-sm py-8">No photos submitted.</div>
    <% end %>

    <div class="card">
      <div class="flex items-start justify-between mb-3">
        <div>
          <h1 class="text-lg font-bold text-slate-900"><%= @book.title %></h1>
          <p class="text-slate-500 text-sm">by <%= @book.author %></p>
        </div>
        <span class="badge-pill flex-shrink-0 <%= case @book.submission_status
          when 'pending_review' then 'bg-amber-100 text-amber-700'
          when 'approved'       then 'bg-emerald-100 text-emerald-700'
          when 'rejected'       then 'bg-red-100 text-red-700'
          end %>"><%= @book.submission_status_label %></span>
      </div>

      <div class="space-y-2 text-sm border-t border-slate-100 pt-3">
        <% if @book.isbn.present? %>
          <div class="flex justify-between"><span class="text-slate-500">ISBN</span><span class="font-medium"><%= @book.isbn %></span></div>
        <% end %>
        <div class="flex justify-between"><span class="text-slate-500">Condition</span><span class="font-medium"><%= @book.condition_label.presence || '—' %></span></div>
        <% if @book.maturity_rating.present? %>
          <div class="flex justify-between"><span class="text-slate-500">Maturity</span>
            <span class="badge-pill <%= @book.maturity_rating == 'MATURE' ? 'bg-red-100 text-red-700' : 'bg-slate-100 text-slate-500' %>">
              <%= @book.maturity_rating.gsub('_', ' ').capitalize %>
            </span>
          </div>
        <% end %>
        <div class="flex justify-between"><span class="text-slate-500">Submitted by</span>
          <%= link_to @book.user.username, admin_user_path(@book.user), class: "font-medium text-indigo-600 hover:underline" %>
        </div>
        <div class="flex justify-between"><span class="text-slate-500">User ID</span>
          <span class="font-mono text-xs text-slate-400"><%= @book.user.public_id %></span>
        </div>
        <div class="flex justify-between"><span class="text-slate-500">Flagged</span>
          <span class="badge-pill <%= @book.flagged? ? 'bg-red-100 text-red-700' : 'bg-slate-100 text-slate-500' %>"><%= @book.flagged? ? '🚩 Yes' : 'No' %></span>
        </div>
        <% if @book.preferred_location.present? %>
          <div class="flex justify-between"><span class="text-slate-500">Preferred location</span><span class="font-medium text-slate-700 text-right max-w-[120px]"><%= @book.preferred_location.name %></span></div>
        <% end %>
        <div class="flex justify-between"><span class="text-slate-500">Submitted</span><span class="text-slate-500"><%= @book.created_at.strftime("%b %d, %Y") %></span></div>
      </div>

      <% if @book.submission_notes.present? %>
        <div class="mt-3 pt-3 border-t border-slate-100">
          <p class="text-slate-500 text-xs font-medium uppercase tracking-wide mb-1">Submission Notes</p>
          <p class="text-slate-700 text-sm"><%= @book.submission_notes %></p>
        </div>
      <% end %>

      <% if @book.rejection_reason.present? %>
        <div class="mt-3 pt-3 border-t border-slate-100">
          <p class="text-red-500 text-xs font-medium uppercase tracking-wide mb-1">Rejection Reason</p>
          <p class="text-red-700 text-sm"><%= @book.rejection_reason %></p>
        </div>
      <% end %>
    </div>
  </div>

  <%# ── Right: AI Review + Actions + Labels + Finds ────────────────────────── %>
  <div class="col-span-2 space-y-4">

    <%# AI Review Panel — streaming %>
    <div class="card" id="ai-panel">
      <div class="flex items-center justify-between mb-3">
        <h2 class="text-base font-semibold text-slate-800">🤖 AI Pre-Screen</h2>
        <div class="flex items-center gap-2">
          <span id="ai-reviewed-at" class="text-xs text-slate-400">
            <% if @book.ai_reviewed? %>Reviewed <%= @book.ai_reviewed_at.strftime("%b %d at %H:%M") %><% end %>
          </span>
          <button id="ai-run-btn"
                  onclick="startAiStream('<%= stream_ai_review_admin_book_path(@book) %>', 'book')"
                  class="btn-secondary text-xs py-1 px-2.5">
            <%= @book.ai_reviewed? ? "↻ Re-run" : "▶ Run Review" %>
          </button>
        </div>
      </div>

      <%# Recommendation pill — updated live by JS %>
      <div id="ai-rec-pill" class="mb-3 <%= @book.ai_review.present? ? '' : 'hidden' %>">
        <%
          keyword = if @book.ai_review.to_s.include?('LOOKS GOOD') then 'LOOKS GOOD'
                    elsif @book.ai_review.to_s.include?('LIKELY REJECT') then 'LIKELY REJECT'
                    elsif @book.ai_review.to_s.include?('NEEDS HUMAN ATTENTION') then 'NEEDS HUMAN ATTENTION'
                    end
          rec_class = case keyword
                      when 'LOOKS GOOD'            then 'bg-emerald-100 text-emerald-700'
                      when 'LIKELY REJECT'          then 'bg-red-100 text-red-700'
                      when 'NEEDS HUMAN ATTENTION'  then 'bg-amber-100 text-amber-700'
                      else                              'bg-slate-100 text-slate-600'
                      end
        %>
        <span id="ai-rec-badge" class="badge-pill <%= rec_class %> text-sm px-3 py-1 font-semibold">
          <%= keyword || '' %>
        </span>
      </div>

      <%# Markdown content area %>
      <div id="ai-content-area"
           class="bg-slate-50 rounded-xl p-4 text-sm text-slate-700 overflow-auto max-h-[32rem] prose-ai <%= @book.ai_review.present? ? '' : 'hidden' %>">
        <div id="ai-md-output"></div>
      </div>

      <%# Streaming status indicator %>
      <div id="ai-streaming-indicator" class="hidden flex items-center gap-2 text-slate-400 text-sm py-2">
        <span class="inline-block w-2 h-2 rounded-full bg-indigo-400 animate-pulse"></span>
        <span>AI is thinking…</span>
      </div>

      <%# Empty state %>
      <div id="ai-empty-state" class="<%= @book.ai_review.present? ? 'hidden' : '' %>">
        <p class="text-slate-400 text-sm py-2">No AI review yet. Click <strong>▶ Run Review</strong> to start live streaming.</p>
      </div>

      <%# Seed existing review content into JS %>
      <% if @book.ai_review.present? %>
        <script>document.addEventListener('DOMContentLoaded', () => renderAiMarkdown("<%= j @book.ai_review %>", 'book'));</script>
      <% end %>
    </div>

    <%# Review Actions %>
    <% if @book.pending? %>
      <div class="card border-2 border-amber-200 bg-amber-50">
        <h2 class="text-base font-semibold text-amber-800 mb-4">⏳ Review This Submission</h2>
        <div class="grid grid-cols-2 gap-3">
          <button type="button" onclick="document.getElementById('modal-approve').showModal()"
                  class="btn-success w-full text-center">✅ Approve</button>
          <button type="button" onclick="document.getElementById('modal-reject').showModal()"
                  class="btn-danger w-full text-center">❌ Reject</button>
        </div>
      </div>
    <% else %>
      <div class="card">
        <h2 class="text-base font-semibold text-slate-800 mb-3">Actions</h2>
        <div class="flex flex-wrap gap-2">
          <% if @book.rejected? %>
            <button type="button" onclick="document.getElementById('modal-approve').showModal()"
                    class="btn-success text-sm py-1.5 px-3">✅ Approve</button>
          <% end %>
          <% if @book.flagged? %>
            <%= button_to "Clear Flag", unflag_admin_book_path(@book), method: :patch, class: "btn-secondary text-sm py-1.5 px-3" %>
          <% else %>
            <button type="button" onclick="document.getElementById('modal-flag').showModal()"
                    class="btn-secondary text-sm py-1.5 px-3">🚩 Flag</button>
          <% end %>
          <%= link_to "Edit", edit_admin_book_path(@book), class: "btn-secondary text-sm py-1.5 px-3" %>
          <button type="button" onclick="document.getElementById('modal-delete').showModal()"
                  class="btn-danger text-sm py-1.5 px-3">Delete</button>
        </div>
      </div>
    <% end %>

    <div class="card p-0 overflow-hidden">
      <div class="px-5 py-3 border-b border-slate-100 font-semibold text-slate-800">Labels (<%= @labels.count %>)</div>
      <% if @labels.any? %>
        <div class="divide-y divide-slate-100">
          <% @labels.each do |label| %>
            <div class="px-5 py-3 flex justify-between text-sm items-center">
              <span class="text-slate-700"><%= label.location.name %></span>
              <div class="flex items-center gap-3">
                <span class="badge-pill <%= label.status == 'placed' ? 'bg-emerald-100 text-emerald-700' : label.status == 'invalidated' ? 'bg-red-100 text-red-700' : 'bg-slate-100 text-slate-600' %>"><%= label.status %></span>
                <%= link_to "Manage", admin_label_path(label), class: "text-indigo-600 hover:underline" %>
              </div>
            </div>
          <% end %>
        </div>
      <% else %>
        <p class="px-5 py-4 text-slate-400 text-sm">No labels yet — will be created on approval.</p>
      <% end %>
    </div>

    <div class="card p-0 overflow-hidden">
      <div class="px-5 py-3 border-b border-slate-100 font-semibold text-slate-800">Finds (<%= @finds.count %>)</div>
      <% if @finds.any? %>
        <div class="divide-y divide-slate-100">
          <% @finds.each do |find| %>
            <div class="px-5 py-3 flex justify-between text-sm">
              <%= link_to find.user.username, admin_user_path(find.user), class: "font-medium text-slate-700 hover:text-indigo-600" %>
              <span class="text-slate-400"><%= find.found_at.strftime("%b %d, %Y") %> · +<%= find.points_awarded %> pts</span>
            </div>
          <% end %>
        </div>
      <% else %>
        <p class="px-5 py-4 text-slate-400 text-sm">No finds yet.</p>
      <% end %>
    </div>

  </div>
</div>
