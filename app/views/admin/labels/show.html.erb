<div class="flex items-center gap-3 mb-6">
  <%= link_to "← Labels", admin_labels_path, class: "text-slate-400 hover:text-slate-600 text-sm" %>
</div>

<%# Modal %>
<%= render "shared/modal",
      id: "modal-delete-label",
      title: "Delete this label?",
      body: "The QR code will stop working and any associated finds will remain. This cannot be undone.",
      confirm_label: "Delete Label",
      confirm_class: "btn-danger",
      form_action: admin_label_path(@label),
      form_method: :delete %>

<div class="max-w-lg">
  <h1 class="page-title">Label #<%= @label.id %></h1>
  <div class="card mt-4 mb-4">
    <div class="grid grid-cols-2 gap-4 text-sm">
      <div><span class="text-slate-500">Book</span><p class="font-medium"><%= link_to @label.book.title, admin_book_path(@label.book), class: "text-indigo-600 hover:underline" %></p></div>
      <div><span class="text-slate-500">Location</span><p class="font-medium"><%= @label.location.name %></p></div>
      <div><span class="text-slate-500">Owner</span><p class="font-medium"><%= link_to @label.user.username, admin_user_path(@label.user), class: "text-indigo-600 hover:underline" %></p></div>
      <div><span class="text-slate-500">QR Code</span><p class="font-mono text-xs text-slate-600"><%= @label.qr_code %></p></div>
      <div><span class="text-slate-500">Created</span><p class="font-medium"><%= @label.created_at.strftime("%b %d, %Y") %></p></div>
    </div>
  </div>

  <div class="card mb-4">
    <h2 class="text-base font-semibold text-slate-800 mb-4">Override Status</h2>
    <%= form_with url: admin_label_path(@label), method: :patch do |f| %>
      <div class="form-group">
        <label class="form-label">Status</label>
        <%= select_tag "label[status]",
            options_for_select(Label::STATUSES.map { |s| [s.capitalize, s] }, @label.status),
            class: "form-input" %>
      </div>
      <div class="mt-4">
        <%= f.submit "Update Status", class: "btn-primary" %>
      </div>
    <% end %>
  </div>

  <div class="card">
    <h2 class="text-base font-semibold text-slate-800 mb-3">Danger Zone</h2>
    <button type="button" onclick="document.getElementById('modal-delete-label').showModal()"
            class="btn-danger">Delete Label</button>
  </div>
</div>
