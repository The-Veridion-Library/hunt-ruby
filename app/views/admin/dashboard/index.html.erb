<div class="mb-7">
  <h1 class="text-2xl font-bold" style="color:#2d2520;">Dashboard</h1>
  <p class="text-sm mt-0.5" style="color:#8a7a6a;">App overview — <%= Date.today.strftime("%B %d, %Y") %></p>
</div>

<%# ── Stat cards ── %>
<div class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
  <div class="rounded-xl p-5" style="background:#fffdf9; border:1px solid #e8e0d0;">
    <div class="text-3xl font-bold" style="color:#d97706;"><%= @stats[:total_users] %></div>
    <div class="text-sm mt-1 font-medium" style="color:#4a3828;">Total Users</div>
    <div class="text-xs mt-0.5" style="color:#16a34a;">+<%= @stats[:new_users_week] %> this week</div>
  </div>
  <div class="rounded-xl p-5" style="background:#fffdf9; border:1px solid #e8e0d0;">
    <div class="text-3xl font-bold" style="color:#d97706;"><%= @stats[:total_books] %></div>
    <div class="text-sm mt-1 font-medium" style="color:#4a3828;">Total Books</div>
    <div class="text-xs mt-0.5" style="color:#8a7a6a;"><%= @stats[:books_hidden] %> hidden · <%= @stats[:books_found] %> found</div>
  </div>
  <div class="rounded-xl p-5" style="background:#fffdf9; border:1px solid #e8e0d0;">
    <div class="text-3xl font-bold" style="color:#d97706;"><%= @stats[:total_finds] %></div>
    <div class="text-sm mt-1 font-medium" style="color:#4a3828;">Total Finds</div>
    <div class="text-xs mt-0.5" style="color:#8a7a6a;"><%= @stats[:finds_today] %> today · <%= @stats[:finds_week] %> this week</div>
  </div>
  <div class="rounded-xl p-5" style="background:#fffdf9; border:1px solid #e8e0d0;">
    <div class="text-3xl font-bold" style="color:#d97706;"><%= @stats[:labels_by_status]['placed'] || 0 %></div>
    <div class="text-sm mt-1 font-medium" style="color:#4a3828;">Active Labels</div>
    <div class="text-xs mt-0.5" style="color:#8a7a6a;"><%= @stats[:labels_by_status].values.sum %> total labels</div>
  </div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-2 gap-6">

  <%# Recent finds %>
  <div class="rounded-xl overflow-hidden" style="background:#fffdf9; border:1px solid #e8e0d0;">
    <div class="px-5 py-4 flex items-center justify-between" style="border-bottom:1px solid #e8e0d0;">
      <h2 class="font-semibold" style="color:#2d2520;">Recent Finds</h2>
      <%= link_to "View all →", admin_books_path, class: "text-sm font-medium", style: "color:#d97706;" %>
    </div>
    <div>
      <% @recent_finds.each do |find| %>
        <div class="px-5 py-3 flex items-center justify-between text-sm" style="border-bottom:1px solid #f5f0e8;">
          <div>
            <span class="font-medium" style="color:#2d2520;"><%= find.user.username %></span>
            <span style="color:#8a7a6a;"> found </span>
            <span class="font-medium" style="color:#4a3828;"><%= find.book.title.truncate(35) %></span>
          </div>
          <span class="text-xs" style="color:#a8927c;"><%= time_ago_in_words(find.found_at) %> ago</span>
        </div>
      <% end %>
    </div>
  </div>

  <%# Recent users + books %>
  <div class="space-y-6">
    <div class="rounded-xl overflow-hidden" style="background:#fffdf9; border:1px solid #e8e0d0;">
      <div class="px-5 py-4 flex items-center justify-between" style="border-bottom:1px solid #e8e0d0;">
        <h2 class="font-semibold" style="color:#2d2520;">New Users</h2>
        <%= link_to "View all →", admin_users_path, class: "text-sm font-medium", style: "color:#d97706;" %>
      </div>
      <div>
        <% @recent_users.each do |user| %>
          <div class="px-5 py-3 flex items-center justify-between text-sm" style="border-bottom:1px solid #f5f0e8;">
            <%= link_to user.username, admin_user_path(user), class: "font-medium hover:underline", style: "color:#2d2520;" %>
            <div class="flex items-center gap-2">
              <% if user.admin? %>
                <span class="badge-pill text-xs" style="background:#fee2e2; color:#b91c1c;">admin</span>
              <% end %>
              <span class="text-xs" style="color:#a8927c;"><%= user.created_at.strftime("%b %d") %></span>
            </div>
          </div>
        <% end %>
      </div>
    </div>

    <div class="rounded-xl overflow-hidden" style="background:#fffdf9; border:1px solid #e8e0d0;">
      <div class="px-5 py-4 flex items-center justify-between" style="border-bottom:1px solid #e8e0d0;">
        <h2 class="font-semibold" style="color:#2d2520;">Recent Books</h2>
        <%= link_to "View all →", admin_books_path, class: "text-sm font-medium", style: "color:#d97706;" %>
      </div>
      <div>
        <% @recent_books.each do |book| %>
          <div class="px-5 py-3 flex items-center justify-between text-sm" style="border-bottom:1px solid #f5f0e8;">
            <%= link_to book.title.truncate(35), admin_book_path(book), class: "font-medium hover:underline", style: "color:#2d2520;" %>
            <span class="badge-pill text-xs" style="<%= book.status == 'hidden' ? 'background:#fef3c7; color:#92400e;' : 'background:#d1fae5; color:#065f46;' %>">
              <%= book.status %>
            </span>
          </div>
        <% end %>
      </div>
    </div>
  </div>

</div>