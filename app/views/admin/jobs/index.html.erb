<div class="flex items-center justify-between mb-6">
  <div>
    <h1 class="page-title">⚙️ Jobs</h1>
    <p class="text-slate-500 text-sm">Solid Queue — background job monitor</p>
  </div>
  <% if @solid_queue_available %>
    <div class="flex items-center gap-3">
      <button onclick="window.location.reload()" class="btn-secondary text-sm py-1.5 px-3">↻ Refresh</button>
      <% if @stats[:failed] > 0 %>
        <%= button_to "🗑 Clear Failed (#{@stats[:failed]})", clear_failed_admin_jobs_path,
            method: :delete,
            class: "btn-danger text-sm py-1.5 px-3",
            data: { confirm: "Permanently discard all #{@stats[:failed]} failed jobs?" } %>
      <% end %>
    </div>
  <% end %>
</div>

<% unless @solid_queue_available %>
  <div class="card border border-amber-200 bg-amber-50 max-w-2xl">
    <h2 class="text-base font-semibold text-amber-800 mb-3">⚠️ Solid Queue tables not found</h2>
    <p class="text-amber-700 text-sm mb-4">Solid Queue is installed but its database tables haven't been created yet. Run these commands to fix it:</p>
    <div class="bg-slate-900 text-green-400 font-mono text-sm rounded-lg p-4 mb-4 select-all">
      bin/rails solid_queue:install<br>
      bin/rails db:migrate
    </div>
    <p class="text-amber-600 text-xs">After migrating, refresh this page.</p>
  </div>
<% else %>

  <%# ── Stats row ──────────────────────────────────────────────────────────── %>
  <div class="grid grid-cols-5 gap-3 mb-6">
    <% [
      { label: "Ready",      count: @stats[:ready],           color: "bg-blue-50 text-blue-700 border-blue-100",    icon: "⏳" },
      { label: "Running",    count: @stats[:claimed],         color: "bg-indigo-50 text-indigo-700 border-indigo-100", icon: "⚡" },
      { label: "Scheduled",  count: @stats[:scheduled],       color: "bg-slate-50 text-slate-700 border-slate-200", icon: "🕐" },
      { label: "Failed",     count: @stats[:failed],          color: @stats[:failed] > 0 ? "bg-red-50 text-red-700 border-red-100" : "bg-slate-50 text-slate-700 border-slate-200", icon: "❌" },
      { label: "Done Today", count: @stats[:completed_today], color: "bg-emerald-50 text-emerald-700 border-emerald-100", icon: "✅" },
    ].each do |stat| %>
      <div class="card border p-4 text-center <%= stat[:color] %>">
        <p class="text-2xl mb-1"><%= stat[:icon] %></p>
        <p class="text-2xl font-bold"><%= stat[:count] %></p>
        <p class="text-xs font-medium mt-0.5"><%= stat[:label] %></p>
      </div>
    <% end %>
  </div>

  <%# ── Running / Claimed ───────────────────────────────────────────────────── %>
  <% if @claimed.any? %>
    <div class="card p-0 overflow-hidden mb-4">
      <div class="px-5 py-3 border-b border-slate-100 font-semibold text-slate-800 flex items-center gap-2">
        <span class="w-2 h-2 rounded-full bg-indigo-500 animate-pulse inline-block"></span>
        Running (<%= @stats[:claimed] %>)
      </div>
      <table class="w-full text-sm">
        <thead class="bg-slate-50 border-b border-slate-100">
          <tr>
            <th class="text-left px-5 py-2 text-slate-500 font-medium">Job Class</th>
            <th class="text-left px-5 py-2 text-slate-500 font-medium">Queue</th>
            <th class="text-left px-5 py-2 text-slate-500 font-medium">Process</th>
            <th class="text-left px-5 py-2 text-slate-500 font-medium">Started</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-100">
          <% @claimed.each do |exec| %>
            <tr class="bg-indigo-50">
              <td class="px-5 py-2.5 font-mono font-medium text-indigo-800"><%= exec.job.class_name %></td>
              <td class="px-5 py-2.5 text-slate-500"><%= exec.job.queue_name %></td>
              <td class="px-5 py-2.5 text-slate-400 text-xs font-mono"><%= exec.process_id %></td>
              <td class="px-5 py-2.5 text-slate-400"><%= time_ago_in_words(exec.created_at) %> ago</td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% end %>

  <%# ── Ready / Queued ──────────────────────────────────────────────────────── %>
  <div class="card p-0 overflow-hidden mb-4">
    <div class="px-5 py-3 border-b border-slate-100 font-semibold text-slate-800">
      ⏳ Ready / Queued (<%= @stats[:ready] %>)
    </div>
    <% if @ready.any? %>
      <table class="w-full text-sm">
        <thead class="bg-slate-50 border-b border-slate-100">
          <tr>
            <th class="text-left px-5 py-2 text-slate-500 font-medium">Job Class</th>
            <th class="text-left px-5 py-2 text-slate-500 font-medium">Queue</th>
            <th class="text-left px-5 py-2 text-slate-500 font-medium">Priority</th>
            <th class="text-left px-5 py-2 text-slate-500 font-medium">Queued</th>
            <th class="text-left px-5 py-2 text-slate-500 font-medium">Arguments</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-100">
          <% @ready.each do |exec| %>
            <tr class="hover:bg-slate-50">
              <td class="px-5 py-2.5 font-mono font-medium text-slate-800"><%= exec.job.class_name %></td>
              <td class="px-5 py-2.5"><span class="badge-pill bg-blue-100 text-blue-700"><%= exec.job.queue_name %></span></td>
              <td class="px-5 py-2.5 text-slate-500"><%= exec.job.priority || 0 %></td>
              <td class="px-5 py-2.5 text-slate-400"><%= time_ago_in_words(exec.created_at) %> ago</td>
              <td class="px-5 py-2.5 text-slate-400 font-mono text-xs max-w-[200px] truncate">
                <%= begin
                      args = JSON.parse(exec.job.arguments)
                      args['arguments']&.inspect&.truncate(60)
                    rescue
                      exec.job.arguments.to_s.truncate(60)
                    end %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% else %>
      <p class="px-5 py-6 text-slate-400 text-sm text-center">No jobs queued.</p>
    <% end %>
  </div>

  <%# ── Scheduled ───────────────────────────────────────────────────────────── %>
  <% if @scheduled.any? %>
    <div class="card p-0 overflow-hidden mb-4">
      <div class="px-5 py-3 border-b border-slate-100 font-semibold text-slate-800">🕐 Scheduled (<%= @stats[:scheduled] %>)</div>
      <table class="w-full text-sm">
        <thead class="bg-slate-50 border-b border-slate-100">
          <tr>
            <th class="text-left px-5 py-2 text-slate-500 font-medium">Job Class</th>
            <th class="text-left px-5 py-2 text-slate-500 font-medium">Queue</th>
            <th class="text-left px-5 py-2 text-slate-500 font-medium">Scheduled At</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-100">
          <% @scheduled.each do |exec| %>
            <tr class="hover:bg-slate-50">
              <td class="px-5 py-2.5 font-mono font-medium text-slate-800"><%= exec.job.class_name %></td>
              <td class="px-5 py-2.5 text-slate-500"><%= exec.job.queue_name %></td>
              <td class="px-5 py-2.5 text-slate-400"><%= exec.scheduled_at.strftime("%b %d %H:%M:%S") %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% end %>

  <%# ── Failed ───────────────────────────────────────────────────────────────── %>
  <div class="card p-0 overflow-hidden">
    <div class="px-5 py-3 border-b border-slate-100 font-semibold text-slate-800 flex items-center justify-between">
      <span>❌ Failed (<%= @stats[:failed] %>)</span>
      <% if @stats[:failed] > 100 %>
        <span class="text-xs text-slate-400">Showing last 100</span>
      <% end %>
    </div>
    <% if @failed.any? %>
      <div class="divide-y divide-slate-100">
        <% @failed.each do |exec| %>
          <details class="group">
            <summary class="px-5 py-3 flex items-center justify-between cursor-pointer hover:bg-red-50 list-none">
              <div class="flex items-center gap-3">
                <span class="text-red-500">✕</span>
                <div>
                  <p class="font-mono font-medium text-slate-800 text-sm"><%= exec.job.class_name %></p>
                  <p class="text-slate-400 text-xs"><%= exec.job.queue_name %> · Failed <%= time_ago_in_words(exec.created_at) %> ago</p>
                </div>
              </div>
              <div class="flex items-center gap-3">
                <% begin
                     error_data = JSON.parse(exec.error)
                     error_class = error_data['class_name'] || error_data['exception_class'] || 'Error'
                   rescue
                     error_class = 'Error'
                   end %>
                <span class="badge-pill bg-red-100 text-red-700 text-xs"><%= error_class %></span>
                <span class="text-slate-400 text-xs group-open:rotate-180 transition-transform">▼</span>
              </div>
            </summary>
            <div class="px-5 pb-4 bg-red-50">
              <% begin
                   error_data = JSON.parse(exec.error)
                   error_msg  = error_data['message'] || error_data['exception_message'] || exec.error
                   error_bt   = error_data['backtrace'] || []
                 rescue
                   error_msg = exec.error.to_s
                   error_bt  = []
                 end %>
              <div class="bg-white border border-red-200 rounded-lg p-3 mb-3 text-sm font-mono text-red-700 break-all">
                <%= error_msg %>
              </div>
              <div class="text-xs text-slate-500 mb-2">
                <strong>Arguments:</strong>
                <span class="font-mono">
                  <%= begin
                        args = JSON.parse(exec.job.arguments)
                        args['arguments']&.inspect
                      rescue
                        exec.job.arguments.to_s
                      end %>
                </span>
              </div>
              <% if error_bt.any? %>
                <div class="bg-slate-900 text-slate-300 rounded-lg p-3 text-xs font-mono overflow-auto max-h-40">
                  <% error_bt.first(10).each do |line| %>
                    <div class="<%= line.include?('app/') ? 'text-amber-300' : '' %>"><%= line %></div>
                  <% end %>
                  <% if error_bt.size > 10 %>
                    <div class="text-slate-500 mt-1">… <%= error_bt.size - 10 %> more lines</div>
                  <% end %>
                </div>
              <% end %>
            </div>
          </details>
        <% end %>
      </div>
    <% else %>
      <p class="px-5 py-6 text-slate-400 text-sm text-center">No failed jobs. 🎉</p>
    <% end %>
  </div>

<% end %>
