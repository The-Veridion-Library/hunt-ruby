<div class="max-w-2xl">
  <!-- Profile header -->
  <div class="card mb-6">
    <div class="flex items-start justify-between gap-4">
      <div class="flex items-center gap-4">
        <div class="w-16 h-16 rounded-full bg-indigo-100 text-indigo-700 flex items-center justify-center font-bold text-2xl">
          <%= @profile_user.username.first.upcase %>
        </div>
        <div>
          <h1 class="text-2xl font-bold text-slate-900"><%= @profile_user.username %></h1>
          <% if @profile_user.bio.present? %>
            <p class="text-slate-500 text-sm mt-0.5"><%= @profile_user.bio %></p>
          <% end %>
        </div>
      </div>
      <% if user_signed_in? && @profile_user != current_user %>
        <% existing = Friendship.find_by(user: current_user, friend: @profile_user) %>
        <% if existing.nil? %>
          <%= button_to "➕ Add Friend", friendships_path(friend_id: @profile_user.id), method: :post, class: "btn-primary text-sm py-1.5 px-4 flex-shrink-0" %>
        <% elsif existing.status == 'pending' %>
          <span class="badge-pill bg-slate-100 text-slate-500">⏳ Pending</span>
        <% else %>
          <span class="badge-pill bg-emerald-100 text-emerald-700">✅ Friends</span>
        <% end %>
      <% end %>
    </div>

    <div class="grid grid-cols-3 gap-4 mt-6 pt-6 border-t border-slate-100 text-center">
      <div>
        <div class="text-2xl font-bold text-slate-800"><%= @points %></div>
        <div class="text-xs text-slate-500 mt-0.5">Points</div>
      </div>
      <div>
        <div class="text-2xl font-bold text-slate-800"><%= @hidden_books.count %></div>
        <div class="text-xs text-slate-500 mt-0.5">Books Hidden</div>
      </div>
      <div>
        <div class="text-2xl font-bold text-slate-800"><%= @finds.count %></div>
        <div class="text-xs text-slate-500 mt-0.5">Books Found</div>
      </div>
    </div>
  </div>

  <!-- Badges -->
  <div class="card mb-6">
    <h2 class="text-lg font-semibold text-slate-800 mb-4">🏅 Badges</h2>
    <% if @badges.any? %>
      <div class="flex flex-wrap gap-3">
        <% @badges.each do |badge| %>
          <div class="flex flex-col items-center text-center p-4 rounded-xl border border-slate-100 bg-slate-50 w-28">
            <div class="text-3xl mb-1"><%= badge.icon %></div>
            <div class="font-semibold text-slate-700 text-sm"><%= badge.name %></div>
            <div class="text-xs text-slate-400 mt-0.5"><%= badge.description %></div>
          </div>
        <% end %>
      </div>
    <% else %>
      <p class="text-slate-400 text-sm">No badges yet — get out there and find some books!</p>
    <% end %>
  </div>

  <!-- Recent finds -->
  <div class="card mb-6">
    <h2 class="text-lg font-semibold text-slate-800 mb-4">🎯 Recent Finds</h2>
    <% if @finds.any? %>
      <div class="space-y-3">
        <% @finds.each do |find| %>
          <div class="flex items-start gap-3 py-3 border-b border-slate-100 last:border-0">
            <% if find.photo.present? %>
              <img src="<%= find.photo %>" class="w-12 h-12 object-cover rounded-lg flex-shrink-0">
            <% else %>
              <div class="w-12 h-12 bg-slate-100 rounded-lg flex items-center justify-center text-xl flex-shrink-0">📖</div>
            <% end %>
            <div>
              <p class="font-medium text-slate-800"><%= find.book.title %></p>
              <p class="text-slate-500 text-xs">by <%= find.book.author %></p>
              <p class="text-slate-400 text-xs mt-0.5"><%= find.found_at.strftime("%B %d, %Y") %> · <span class="text-amber-600 font-medium">+<%= find.points_awarded %> pts</span></p>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <p class="text-slate-400 text-sm">No finds yet.</p>
    <% end %>
  </div>

  <!-- Books hidden -->
  <div class="card">
    <h2 class="text-lg font-semibold text-slate-800 mb-4">📚 Books Hidden</h2>
    <% if @hidden_books.any? %>
      <div class="space-y-3">
        <% @hidden_books.each do |book| %>
          <div class="flex items-center justify-between py-3 border-b border-slate-100 last:border-0">
            <div>
              <%= link_to book.title, book_path(book), class: "font-medium text-slate-800 hover:text-indigo-600" %>
              <p class="text-slate-500 text-xs">by <%= book.author %></p>
            </div>
            <span class="badge-pill <%= book.status == 'hidden' ? 'bg-amber-100 text-amber-700' : 'bg-emerald-100 text-emerald-700' %>"><%= book.status.capitalize %></span>
          </div>
        <% end %>
      </div>
    <% else %>
      <p class="text-slate-400 text-sm">No books hidden yet.</p>
    <% end %>
  </div>
</div>
