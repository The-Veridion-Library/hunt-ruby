<div class="flex items-center justify-between mb-6">
  <div>
    <h1 class="page-title">📍 Locations</h1>
    <p class="page-subtitle">Places where books have been hidden</p>
  </div>
  <%= link_to "Add Location", new_location_path, class: "btn-primary" %>
</div>

<% if @locations&.any? %>
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
    <% @locations.each do |location| %>
      <div class="card hover:shadow-md transition-shadow">
        <div class="flex items-start justify-between">
          <div>
            <h2 class="font-semibold text-slate-800"><%= location.name %></h2>
            <span class="badge-pill bg-slate-100 text-slate-600 mt-1"><%= location.location_type&.capitalize %></span>
          </div>
          <span class="text-2xl"><%= { 'library' => '📚', 'bookstore' => '🏪', 'cafe' => '☕', 'park' => '🌳', 'other' => '📍' }[location.location_type] || '📍' %></span>
        </div>
        <% if location.city.present? %>
          <p class="text-slate-500 text-sm mt-3">📍 <%= [location.city, location.state].compact.join(', ') %></p>
        <% end %>
      </div>
    <% end %>
  </div>
<% else %>
  <div class="card text-center py-12">
    <div class="text-5xl mb-3">📍</div>
    <p class="text-slate-500">No locations yet.</p>
    <%= link_to "Add the first location", new_location_path, class: "btn-primary inline-block mt-4" %>
  </div>
<% end %>
