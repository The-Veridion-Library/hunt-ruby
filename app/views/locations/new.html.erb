<div class="max-w-xl">
  <h1 class="page-title">📍 Add a Location</h1>
  <p class="page-subtitle">Where will hunters find this book?</p>

  <div class="card">
    <%= form_with model: @location do |f| %>
      <% if @location.errors.any? %>
        <div class="error-box">
          <% @location.errors.full_messages.each do |msg| %><p>• <%= msg %></p><% end %>
        </div>
      <% end %>

      <div class="form-group">
        <%= f.label :name, "Location Name", class: "form-label" %>
        <%= f.text_field :name, required: true, placeholder: "e.g. Barnes & Noble Hartford", class: "form-input" %>
      </div>

      <div class="form-group">
        <%= f.label :location_type, "Type", class: "form-label" %>
        <%= f.select :location_type,
            [["Library", "library"], ["Book Store", "bookstore"], ["Café", "cafe"], ["Park", "park"], ["Other", "other"]],
            { prompt: "Select type" }, { required: true, class: "form-input" } %>
      </div>

      <div class="form-group">
        <%= f.label :address_line_1, "Address Line 1", class: "form-label" %>
        <%= f.text_field :address_line_1, required: true, placeholder: "123 Main St", class: "form-input" %>
      </div>

      <div class="form-group">
        <%= f.label :address_line_2, "Address Line 2", class: "form-label" %>
        <%= f.text_field :address_line_2, placeholder: "Suite 100, Floor 2, etc.", class: "form-input" %>
      </div>

      <div class="grid grid-cols-2 gap-4">
        <div class="form-group">
          <%= f.label :city, class: "form-label" %>
          <%= f.text_field :city, required: true, placeholder: "Hartford", class: "form-input" %>
        </div>
        <div class="form-group">
          <%= f.label :state, class: "form-label" %>
          <%= f.select :state, [
            ["Alabama","AL"],["Alaska","AK"],["Arizona","AZ"],["Arkansas","AR"],
            ["California","CA"],["Colorado","CO"],["Connecticut","CT"],["Delaware","DE"],
            ["Florida","FL"],["Georgia","GA"],["Hawaii","HI"],["Idaho","ID"],
            ["Illinois","IL"],["Indiana","IN"],["Iowa","IA"],["Kansas","KS"],
            ["Kentucky","KY"],["Louisiana","LA"],["Maine","ME"],["Maryland","MD"],
            ["Massachusetts","MA"],["Michigan","MI"],["Minnesota","MN"],["Mississippi","MS"],
            ["Missouri","MO"],["Montana","MT"],["Nebraska","NE"],["Nevada","NV"],
            ["New Hampshire","NH"],["New Jersey","NJ"],["New Mexico","NM"],["New York","NY"],
            ["North Carolina","NC"],["North Dakota","ND"],["Ohio","OH"],["Oklahoma","OK"],
            ["Oregon","OR"],["Pennsylvania","PA"],["Rhode Island","RI"],["South Carolina","SC"],
            ["South Dakota","SD"],["Tennessee","TN"],["Texas","TX"],["Utah","UT"],
            ["Vermont","VT"],["Virginia","VA"],["Washington","WA"],["West Virginia","WV"],
            ["Wisconsin","WI"],["Wyoming","WY"]
          ], { prompt: "State" }, { required: true, class: "form-input" } %>
        </div>
      </div>

      <div class="form-group">
        <%= f.label :zip_code, "ZIP Code", class: "form-label" %>
        <%= f.text_field :zip_code, placeholder: "06101", class: "form-input" %>
      </div>

      <div class="border-t border-slate-100 pt-4 mt-2">
        <p class="text-slate-500 text-sm mb-3"><em>Coordinates are filled automatically from the address. Override manually if needed.</em></p>
        <div class="grid grid-cols-2 gap-4">
          <div class="form-group">
            <%= f.label :latitude, class: "form-label" %>
            <%= f.number_field :latitude, step: :any, placeholder: "Auto-filled", class: "form-input" %>
          </div>
          <div class="form-group">
            <%= f.label :longitude, class: "form-label" %>
            <%= f.number_field :longitude, step: :any, placeholder: "Auto-filled", class: "form-input" %>
          </div>
        </div>
      </div>

      <div class="mt-6">
        <%= f.submit "Add Location", class: "btn-primary" %>
      </div>
    <% end %>
  </div>
</div>
