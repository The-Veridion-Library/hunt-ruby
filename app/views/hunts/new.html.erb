<div class="max-w-4xl">
  <h1 class="page-title">✨ Create a Hunt</h1>
  <p class="page-subtitle">Curate a time-limited event with placed books and a dedicated leaderboard</p>

  <div class="card">
    <%= form_with model: @hunt do |f| %>
      <% if @hunt.errors.any? %>
        <div class="error-box">
          <% @hunt.errors.full_messages.each do |msg| %><p>• <%= msg %></p><% end %>
        </div>
      <% end %>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div class="form-group md:col-span-2">
          <%= f.label :title, class: "form-label" %>
          <%= f.text_field :title, class: "form-input", required: true, placeholder: "e.g. Spring Downtown Book Dash" %>
        </div>

        <div class="form-group md:col-span-2">
          <%= f.label :description, class: "form-label" %>
          <%= f.text_area :description, class: "form-input", rows: 3, placeholder: "What makes this hunt fun, where it takes place, and what players should know." %>
        </div>

        <div class="form-group">
          <%= f.label :start_date, class: "form-label" %>
          <%= f.datetime_local_field :start_date, class: "form-input", required: true %>
        </div>

        <div class="form-group">
          <%= f.label :end_date, class: "form-label" %>
          <%= f.datetime_local_field :end_date, class: "form-input", required: true %>
        </div>
      </div>

      <div class="border-t border-slate-100 mt-4 pt-5">
        <div class="flex items-center justify-between mb-3">
          <h2 class="text-base font-semibold text-slate-800">Books in This Hunt</h2>
          <span class="text-xs text-slate-500">Only books with placed labels are selectable</span>
        </div>

        <% if @eligible_books.any? %>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-3 max-h-96 overflow-y-auto pr-1">
            <% @eligible_books.each do |book| %>
              <label class="border border-slate-200 rounded-xl p-3 flex items-start gap-3 hover:bg-slate-50 transition-colors cursor-pointer">
                <%= check_box_tag 'hunt[book_ids][]', book.id, false, class: 'mt-1 w-4 h-4 text-indigo-600 border-slate-300 rounded' %>
                <div class="min-w-0">
                  <p class="font-medium text-slate-800 truncate"><%= book.title %></p>
                  <p class="text-slate-500 text-sm truncate">by <%= book.author %></p>
                  <p class="text-xs text-slate-400 mt-1"><%= pluralize(book.labels.placed.count, 'placed label') %></p>
                </div>
              </label>
            <% end %>
          </div>
        <% else %>
          <div class="bg-amber-50 border border-amber-100 rounded-xl p-4 text-sm text-amber-800">
            There are no eligible books yet. Place at least one label on an approved book to create a hunt.
          </div>
        <% end %>
      </div>

      <div class="flex items-center gap-3 mt-6 pt-5 border-t border-slate-100">
        <%= f.submit "Create Hunt", class: "btn-primary" %>
        <%= link_to "Cancel", hunts_path, class: "btn-secondary" %>
      </div>
    <% end %>
  </div>
</div>
