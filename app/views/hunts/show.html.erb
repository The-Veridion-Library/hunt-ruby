<div class="flex flex-col lg:flex-row lg:items-start lg:justify-between gap-4 mb-6">
  <div>
    <div class="flex items-center gap-2 mb-1">
      <% if @hunt.active? %>
        <span class="badge-pill bg-emerald-100 text-emerald-700">🟢 Active</span>
      <% elsif @hunt.upcoming? %>
        <span class="badge-pill bg-blue-100 text-blue-700">⏳ Upcoming</span>
      <% else %>
        <span class="badge-pill bg-slate-100 text-slate-600">⚑ Ended</span>
      <% end %>
      <span class="text-xs text-slate-500">Created by <%= @hunt.user.username %></span>
    </div>
    <h1 class="page-title"><%= @hunt.title %></h1>
    <p class="text-slate-500 text-sm"><%= @hunt.description %></p>
  </div>

  <div class="card p-4 min-w-64">
    <p class="text-xs text-slate-500 uppercase tracking-wide mb-2">Time Window</p>
    <p class="text-sm text-slate-700"><strong>Start:</strong> <%= @hunt.start_date.strftime("%b %d, %Y %I:%M %p") %></p>
    <p class="text-sm text-slate-700 mt-1"><strong>End:</strong> <%= @hunt.end_date.strftime("%b %d, %Y %I:%M %p") %></p>

    <% if @joined %>
      <div class="mt-3 text-xs bg-emerald-50 border border-emerald-100 text-emerald-700 rounded-lg px-3 py-2">✅ You joined this hunt</div>
    <% elsif !@hunt.ended? %>
      <%= button_to "Join Hunt", hunt_hunt_participants_path(@hunt), method: :post, class: "btn-primary w-full mt-3" %>
    <% end %>
  </div>
</div>

<div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-6">
  <div class="card text-center">
    <p class="text-3xl font-bold text-indigo-600"><%= @hunt.books.count %></p>
    <p class="text-slate-500 text-sm mt-1">Books in Hunt</p>
  </div>
  <div class="card text-center">
    <p class="text-3xl font-bold text-amber-500"><%= @hunt.hunt_participants.count %></p>
    <p class="text-slate-500 text-sm mt-1">Participants</p>
  </div>
  <div class="card text-center">
    <p class="text-3xl font-bold text-emerald-500"><%= @participant&.score.to_i %></p>
    <p class="text-slate-500 text-sm mt-1">Your Hunt Score</p>
  </div>
</div>

<div class="card mb-6 p-0 overflow-hidden">
  <div class="px-6 py-4 border-b border-slate-100 flex items-center justify-between">
    <h2 class="font-semibold text-slate-800">🏆 Hunt Leaderboard</h2>
    <span class="text-xs text-slate-500">Scores are separate from global points</span>
  </div>

  <% if @leaderboard.any? %>
    <table class="w-full text-sm">
      <thead class="bg-slate-50 border-b border-slate-100">
        <tr>
          <th class="text-left px-6 py-3 text-slate-500 font-medium w-16">Rank</th>
          <th class="text-left px-6 py-3 text-slate-500 font-medium">Hunter</th>
          <th class="text-left px-6 py-3 text-slate-500 font-medium">Score</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-slate-100">
        <% @leaderboard.each_with_index do |entry, index| %>
          <tr class="<%= entry.user_id == current_user.id ? 'bg-amber-50' : 'hover:bg-slate-50' %>">
            <td class="px-6 py-4 text-xl">
              <%= index == 0 ? '🥇' : index == 1 ? '🥈' : index == 2 ? '🥉' : "<span class='text-slate-500 text-sm font-medium'>##{index + 1}</span>".html_safe %>
            </td>
            <td class="px-6 py-4">
              <div class="flex items-center gap-3">
                <div class="w-8 h-8 rounded-full bg-indigo-100 text-indigo-700 flex items-center justify-center font-bold text-sm">
                  <%= entry.user.username.first.upcase %>
                </div>
                <div>
                  <%= link_to entry.user.username, profile_path(entry.user.username), class: "font-medium text-slate-800 hover:text-indigo-600" %>
                  <% if entry.user_id == current_user.id %>
                    <span class="text-xs text-amber-600 font-medium ml-1">← you</span>
                  <% end %>
                </div>
              </div>
            </td>
            <td class="px-6 py-4 font-semibold text-slate-700"><%= entry.score %> pts</td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <div class="px-6 py-10 text-center text-slate-500">No participants yet — be the first to join.</div>
  <% end %>
</div>

<div class="grid grid-cols-1 xl:grid-cols-5 gap-6">
  <div class="xl:col-span-3">
    <div class="card p-0 overflow-hidden">
      <div class="px-6 py-4 border-b border-slate-100 flex items-center justify-between">
        <h2 class="font-semibold text-slate-800">🗺 Hunt Map</h2>
        <span class="text-xs text-slate-500"><%= pluralize(@map_points.length, 'book location') %></span>
      </div>
      <% if @map_points.any? %>
        <div id="hunt-map" data-points="<%= json_escape(@map_points.to_json) %>" class="h-[520px] w-full"></div>
        <%= vite_javascript_tag 'hunt_map', defer: true %>
      <% else %>
        <div class="px-6 py-16 text-center text-slate-500">No mappable locations available for this hunt yet.</div>
      <% end %>
    </div>
  </div>

  <div class="xl:col-span-2">
    <div class="card">
      <h2 class="font-semibold text-slate-800 mb-3">📚 Hunt Books</h2>
      <% if @hunt_books.any? %>
        <div class="space-y-3 max-h-[520px] overflow-y-auto pr-1">
          <% @hunt_books.each do |book| %>
            <div class="border border-slate-100 rounded-xl px-3 py-2">
              <p class="font-medium text-slate-800 truncate"><%= book.title %></p>
              <p class="text-slate-500 text-sm truncate">by <%= book.author %></p>
              <%= link_to "View book →", book_path(book), class: "text-indigo-600 hover:underline text-xs font-medium mt-1 inline-block" %>
            </div>
          <% end %>
        </div>
      <% else %>
        <p class="text-slate-500 text-sm">No books in this hunt yet.</p>
      <% end %>
    </div>
  </div>
</div>
