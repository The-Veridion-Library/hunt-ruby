<div class="min-h-[60vh] flex items-center justify-center">
  <div class="w-full max-w-sm">
    <div class="text-center mb-8">
      <div class="text-4xl mb-2">📖</div>
      <h1 class="text-2xl font-bold text-slate-900">Welcome back</h1>
      <p class="text-slate-500 text-sm mt-1">Sign in to continue your hunt</p>
    </div>

    <div class="card">
      <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
        <div class="form-group">
          <%= f.label :email, class: "form-label" %>
          <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "form-input" %>
        </div>

        <div class="form-group">
          <%= f.label :password, class: "form-label" %>
          <%= f.password_field :password, autocomplete: "current-password", class: "form-input" %>
        </div>

        <% if devise_mapping.rememberable? %>
          <div class="flex items-center gap-2 mb-4">
            <%= f.check_box :remember_me, class: "rounded border-slate-300 text-indigo-600" %>
            <%= f.label :remember_me, class: "text-sm text-slate-600 cursor-pointer" %>
          </div>
        <% end %>

        <%= f.submit "Sign In", class: "btn-primary w-full mt-2" %>
      <% end %>
    </div>

    <div class="mt-4 text-center text-sm text-slate-500 space-y-2">
      <%= render "devise/shared/links" %>
    </div>
  </div>
</div>
