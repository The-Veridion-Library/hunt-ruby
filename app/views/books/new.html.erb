<div class="max-w-xl">
  <h1 class="page-title">📚 Hide a Book</h1>
  <p class="page-subtitle">Add your book details and choose where to hide it.</p>

  <div class="card">
    <%= form_with model: @book do |f| %>
      <% if @book.errors.any? %>
        <div class="error-box">
          <% @book.errors.full_messages.each do |msg| %>
            <p>• <%= msg %></p>
          <% end %>
        </div>
      <% end %>

      <div class="form-group">
        <%= f.label :title, class: "form-label" %>
        <%= f.text_field :title, required: true, class: "form-input", placeholder: "e.g. The Hitchhiker's Guide" %>
      </div>

      <div class="form-group">
        <%= f.label :author, class: "form-label" %>
        <%= f.text_field :author, required: true, class: "form-input", placeholder: "e.g. Douglas Adams" %>
      </div>

      <div class="form-group">
        <%= f.label :isbn, "ISBN", class: "form-label" %>
        <%= f.text_field :isbn, class: "form-input", placeholder: "Optional" %>
      </div>

      <div class="form-group">
        <%= f.label :cover_image, "Cover Image URL", class: "form-label" %>
        <%= f.text_field :cover_image, class: "form-input", placeholder: "https://..." %>
      </div>

      <div class="form-group">
        <label for="location_id" class="form-label">Location</label>
        <%= select_tag :location_id,
            options_from_collection_for_select(@locations, :id, :name),
            prompt: "Select a location", required: true, class: "form-input" %>
      </div>

      <div class="flex items-center gap-3 mt-6">
        <%= f.submit "Hide this Book!", class: "btn-primary" %>
        <%= link_to "Add a new location first →", new_location_path, class: "text-indigo-600 hover:underline text-sm" %>
      </div>
    <% end %>
  </div>
</div>
