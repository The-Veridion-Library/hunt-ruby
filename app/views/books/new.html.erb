<%# Step 1: ISBN entry %>
<div class="max-w-lg mx-auto mt-8">
  <div class="text-center mb-8">
    <p class="text-4xl mb-3">📚</p>
    <h1 class="text-2xl font-bold text-slate-800">Submit a Book</h1>
    <p class="text-slate-500 mt-1">Start by entering the book's ISBN-13. We'll look it up automatically.</p>
  </div>

  <div class="card">
    <%= form_with url: isbn_lookup_books_path, method: :post do |f| %>
      <% if alert.present? %>
        <div class="error-box mb-4"><p>⚠️ <%= alert %></p></div>
      <% end %>
      <% if flash.now[:alert].present? %>
        <div class="error-box mb-4"><p>⚠️ <%= flash.now[:alert] %></p></div>
      <% end %>

      <div class="form-group">
        <label class="form-label text-base">ISBN-13</label>
        <p class="text-slate-400 text-xs mb-2">Found on the back cover barcode — 13 digits, usually starting with 978 or 979.</p>
        <%= f.text_field :isbn,
            class: "form-input text-lg font-mono tracking-widest",
            placeholder: "9780000000000",
            maxlength: 17,
            autofocus: true,
            inputmode: "numeric",
            value: params[:isbn] %>
      </div>

      <div class="flex gap-3 mt-2">
        <%= f.submit "Look Up Book →", class: "btn-primary flex-1 text-center" %>
        <%= link_to "Skip →", new_details_books_path, class: "btn-secondary text-center" %>
      </div>
      <p class="text-slate-400 text-xs text-center mt-3">Don't have the ISBN? Click <strong>Skip</strong> to enter the details manually.</p>
    <% end %>
  </div>

  <div class="text-center mt-6 text-sm text-slate-400">
    <p>Step <span class="font-bold text-slate-600">1</span> of 2 — Book lookup</p>
    <div class="flex justify-center gap-2 mt-2">
      <span class="w-8 h-1.5 rounded-full bg-indigo-500"></span>
      <span class="w-8 h-1.5 rounded-full bg-slate-200"></span>
    </div>
  </div>
</div>
