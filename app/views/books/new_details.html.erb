<%# Step 3: Final submission form %>
<div class="max-w-2xl mx-auto">

  <%# Step indicator %>
  <div class="flex items-center gap-3 mb-6">
    <%= link_to "← Back", isbn_lookup_books_path, class: "text-slate-400 hover:text-slate-600 text-sm" %>
    <div class="flex-1"></div>
    <span class="text-sm text-slate-400">Step <span class="font-bold text-slate-600">3</span> of 3 — Submission details</span>
    <div class="flex gap-2">
      <span class="w-8 h-1.5 rounded-full bg-slate-200"></span>
      <span class="w-8 h-1.5 rounded-full bg-slate-200"></span>
      <span class="w-8 h-1.5 rounded-full bg-indigo-500"></span>
    </div>
  </div>

  <h1 class="page-title">📚 Submit a Book</h1>
  <p class="page-subtitle">Add condition, location, and notes to complete your submission.</p>

  <%# Open Library result banner %>
  <% if @ol_found %>
    <div class="bg-emerald-50 border border-emerald-200 rounded-xl px-5 py-4 mb-5 flex gap-4 items-start">
      <% if @prefill&.dig('cover').present? %>
        <img src="<%= @prefill['cover'] %>" class="w-14 h-20 object-cover rounded shadow-sm flex-shrink-0" alt="Cover">
      <% else %>
        <span class="text-3xl flex-shrink-0">✅</span>
      <% end %>
      <div>
        <p class="font-semibold text-emerald-800 text-sm">Book found on Open Library!</p>
        <p class="text-emerald-700 text-sm mt-0.5">We've pre-filled what we could find. Please review and correct anything that looks wrong.</p>
      </div>
    </div>
  <% elsif @prefill&.dig('isbn').present? %>
    <div class="bg-amber-50 border border-amber-100 rounded-xl px-5 py-4 mb-5 flex gap-3 items-start">
      <span class="text-xl flex-shrink-0">⚠️</span>
      <div>
        <p class="font-semibold text-amber-800 text-sm">ISBN not found in Open Library</p>
        <p class="text-amber-700 text-sm mt-0.5">No worries — just fill in the title and author manually below.</p>
      </div>
    </div>
  <% end %>

  <div class="card">
    <%= form_with model: @book, url: books_path do |f| %>
      <%= f.hidden_field :title, value: @prefill&.dig('title') %>
      <%= f.hidden_field :author, value: @prefill&.dig('author') %>
      <%= f.hidden_field :isbn, value: @prefill&.dig('isbn') %>
      <%= f.hidden_field :cover_image, value: @book.cover_image.presence || @prefill&.dig('cover') %>
      <% if @book.errors.any? %>
        <div class="error-box">
          <% @book.errors.full_messages.each do |msg| %><p>• <%= msg %></p><% end %>
        </div>
      <% end %>

      <%# Confirmed Book Details %>
      <h2 class="text-base font-semibold text-slate-800 mb-4">Confirmed Book Details</h2>
      <div class="bg-slate-50 border border-slate-200 rounded-xl p-4 mb-5">
        <p class="text-sm text-slate-700"><span class="font-medium">Title:</span> <%= @prefill&.dig('title').presence || "—" %></p>
        <p class="text-sm text-slate-700 mt-1"><span class="font-medium">Author:</span> <%= @prefill&.dig('author').presence || "—" %></p>
        <p class="text-sm text-slate-700 mt-1"><span class="font-medium">ISBN:</span> <span class="font-mono"><%= @prefill&.dig('isbn').presence || "—" %></span></p>
        <p class="text-xs text-slate-500 mt-3">
          Need to change these?
          <%= link_to "Edit details →", isbn_lookup_books_path, class: "text-indigo-600 hover:underline" %>
        </p>
      </div>

      <div class="form-group">
        <%= f.label :book_condition, "Condition", class: "form-label" %>
        <%= f.select :book_condition,
            [["Like New 🌟", "like_new"], ["Good 👍", "good"], ["Acceptable 👌", "acceptable"], ["Poor 🫤", "poor"]],
            { prompt: "Select condition" }, { required: true, class: "form-input" } %>
      </div>

      <%# Cover Photos %>
      <div class="border-t border-slate-100 pt-5 mt-2">
        <h2 class="text-base font-semibold text-slate-800 mb-1">Cover Photos</h2>
        <p class="text-slate-500 text-sm mb-4">We keep the fetched OpenLibrary cover, plus your actual front and back photos for condition review.</p>

        <% if @ol_found && @prefill&.dig('cover').present? %>
          <div class="bg-slate-50 border border-slate-200 rounded-xl p-4 mb-4 flex gap-4 items-center text-sm text-slate-600">
            <img src="<%= @prefill['cover'] %>" class="w-10 h-14 object-cover rounded shadow-sm">
            <div>
              <p class="font-medium text-slate-700">OpenLibrary cover found</p>
              <p class="text-slate-500 text-xs mt-0.5">This fetched cover will be kept as reference.</p>
            </div>
          </div>
        <% end %>

        <div class="form-group">
          <%= f.label :cover_image, "Fetched OpenLibrary Cover URL", class: "form-label" %>
          <%= text_field_tag :fetched_cover_preview,
              (@book.cover_image.presence || @prefill&.dig('cover') || ""),
              readonly: true,
              class: "form-input bg-slate-50 text-slate-500",
              placeholder: "Not available for this ISBN" %>
        </div>
        <div class="form-group">
          <%= f.label :front_cover, "Your Front Cover Photo URL", class: "form-label" %>
          <%= f.text_field :front_cover, class: "form-input", placeholder: "https://..." %>
        </div>
        <div class="form-group">
          <%= f.label :back_cover, "Your Back Cover Photo URL", class: "form-label" %>
          <%= f.text_field :back_cover, class: "form-input", placeholder: "https://..." %>
        </div>
      </div>

      <%# Notes %>
      <div class="border-t border-slate-100 pt-5 mt-2">
        <h2 class="text-base font-semibold text-slate-800 mb-1">Any Notes?</h2>
        <p class="text-slate-500 text-sm mb-4">Mention anything we should know — strong smells, writing inside, water damage, etc.</p>
        <div class="form-group">
          <%= f.text_area :submission_notes, rows: 3, class: "form-input",
              placeholder: "e.g. Slight musty smell, pencil notes in margins on chapter 3, otherwise great condition." %>
        </div>
      </div>

      <%# Preferred Location %>
      <div class="border-t border-slate-100 pt-5 mt-2">
        <h2 class="text-base font-semibold text-slate-800 mb-1">Preferred Hide Location</h2>
        <p class="text-slate-500 text-sm mb-4">Where would you like to leave this book? Our team will confirm during review.</p>

        <% if @locations.any? %>
          <div class="form-group">
            <%= f.label :preferred_location_id, "Location", class: "form-label" %>
            <%= f.collection_select :preferred_location_id, @locations, :id, :name,
                { prompt: "Select a partner location" }, { class: "form-input" } %>
          </div>
        <% else %>
          <div class="bg-amber-50 border border-amber-100 rounded-xl px-4 py-3 text-sm text-amber-700">
            No partner locations available yet — you can still submit and we'll sort the location during review.
          </div>
        <% end %>

        <p class="text-sm text-slate-400 mt-3">
          Don't see your local library or bookstore?
          <%= link_to "Nominate a location →", new_location_path, class: "text-indigo-600 hover:underline" %>
        </p>
      </div>

      <div class="flex items-center gap-4 mt-6 pt-5 border-t border-slate-100">
        <%= f.submit "Submit for Review", class: "btn-primary" %>
        <%= link_to "← Start over", new_book_path(reset: true), class: "btn-secondary" %>
      </div>
    <% end %>
  </div>
</div>
